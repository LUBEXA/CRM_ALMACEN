@page "/salidas"
@attribute [Authorize(Policy = "Ver:Salidas")]
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Salidas - CRM Almacén</PageTitle>

<h1>📤 Salidas</h1>
<p class="text-muted">Mercancía que sale del almacén al surtir los pedidos del cliente. Se generan automáticamente desde las solicitudes.</p>

@if (mensaje is not null)
{
    <div class="alert @(error ? "alert-danger" : "alert-success")">@mensaje</div>
}

@if (salidas is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Código</th>
                    <th>Producto</th>
                    <th class="text-end">Cantidad</th>
                    <th>Referencia</th>
                    <th>Registró</th>
                    @if (puedeEditar)
                    {
                        <th class="text-end" style="width:200px">Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var s in salidas)
                {
                    var item = s;
                    @if (puedeEditar && editandoId == item.Id)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><code>@item.Producto?.Codigo</code></td>
                            <td>@item.Producto?.Nombre</td>
                            <td class="text-end">
                                <input type="number" min="1" class="form-control form-control-sm text-end" @bind="editCantidad" style="max-width:90px;display:inline-block" />
                            </td>
                            <td><input class="form-control form-control-sm" @bind="editReferencia" /></td>
                            <td class="small text-muted">@item.RegistradoPor</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-primary" @onclick="() => GuardarFilaAsync(item)" disabled="@guardando">
                                        <span class="bi bi-check-lg"></span> Guardar
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicion" disabled="@guardando">
                                        Cancelar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><code>@item.Producto?.Codigo</code></td>
                            <td>@item.Producto?.Nombre</td>
                            <td class="text-end fw-bold text-danger">-@item.Cantidad</td>
                            <td>@item.Referencia</td>
                            <td class="small text-muted">@item.RegistradoPor</td>
                            @if (puedeEditar)
                            {
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => IniciarEdicion(item)" disabled="@guardando">
                                            <span class="bi bi-pencil"></span> Editar
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAsync(item)" disabled="@guardando" title="Eliminar">
                                            <span class="bi bi-trash"></span>
                                        </button>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                }
                @if (salidas.Count == 0)
                {
                    <tr><td colspan="@(puedeEditar ? 7 : 6)" class="text-center text-muted py-4">Sin salidas registradas.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private List<Salida>? salidas;
    private bool puedeEditar;
    private int? clienteId;
    private string? mensaje;
    private bool error;
    private bool guardando;

    private int? editandoId;
    private int editCantidad;
    private string? editReferencia;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        puedeEditar = user.PuedeEditarModulo(ModuloApp.Salidas);
        clienteId = user.ClienteId();
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.Salidas.Include(s => s.Producto).ThenInclude(p => p!.Cliente).AsQueryable();
        if (clienteId is int id)
            query = query.Where(s => s.Producto!.ClienteId == id);

        salidas = await query.OrderByDescending(s => s.Fecha).Take(200).ToListAsync();
    }

    private void IniciarEdicion(Salida s)
    {
        editandoId = s.Id;
        editCantidad = s.Cantidad;
        editReferencia = s.Referencia;
    }

    private void CancelarEdicion() => editandoId = null;

    private async Task GuardarFilaAsync(Salida s)
    {
        mensaje = null;
        error = false;
        if (editCantidad <= 0)
        {
            error = true;
            mensaje = "La cantidad debe ser mayor a cero.";
            return;
        }

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var salida = await db.Salidas.FindAsync(s.Id);
            if (salida is null) return;
            var producto = await db.Productos.FindAsync(salida.ProductoId);
            if (producto is null) return;

            // Cuánto cambia la salida: más cantidad descuenta stock, menos cantidad lo devuelve.
            var delta = editCantidad - salida.Cantidad;
            if (delta > 0 && delta > producto.CantidadDisponible)
            {
                error = true;
                mensaje = $"No hay existencia suficiente. Disponible: {producto.CantidadDisponible}.";
                return;
            }

            producto.CantidadDisponible -= delta;
            salida.Cantidad = editCantidad;
            salida.Referencia = editReferencia;
            await db.SaveChangesAsync();

            mensaje = "Salida actualizada.";
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private async Task EliminarAsync(Salida s)
    {
        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var salida = await db.Salidas.FindAsync(s.Id);
            if (salida is null) return;
            var producto = await db.Productos.FindAsync(salida.ProductoId);
            // Al eliminar la salida, la mercancía regresa a existencia.
            if (producto is not null) producto.CantidadDisponible += salida.Cantidad;
            db.Salidas.Remove(salida);
            await db.SaveChangesAsync();

            mensaje = $"Salida eliminada. Se devolvieron {s.Cantidad} a existencia.";
            error = false;
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }
}
