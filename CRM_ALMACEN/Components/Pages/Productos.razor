@page "/productos"
@attribute [Authorize(Policy = "Ver:Productos")]
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Productos - CRM Almacén</PageTitle>

<h1>📦 Productos</h1>
<p class="text-muted">Catálogo de artículos por cliente.</p>

@if (puedeEditar)
{
<div class="card mb-4">
    <div class="card-header">Registrar nuevo producto</div>
    <div class="card-body">
        <EditForm Model="nuevo" OnValidSubmit="GuardarAsync" FormName="formProducto">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Cliente</label>
                    <InputSelect class="form-select" @bind-Value="nuevo.ClienteId">
                        <option value="0">-- Selecciona --</option>
                        @foreach (var c in clientes)
                        {
                            <option value="@c.Id">@c.Nombre</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Código</label>
                    <InputText class="form-control" @bind-Value="nuevo.Codigo" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-control" @bind-Value="nuevo.Nombre" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Unidad</label>
                    <InputText class="form-control" @bind-Value="nuevo.UnidadMedida" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ubicación en almacén</label>
                    <InputText class="form-control" @bind-Value="nuevo.Ubicacion" placeholder="Ej. Pasillo 3 / Rack B / Nivel 2" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Descripción</label>
                    <InputText class="form-control" @bind-Value="nuevo.Descripcion" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3">Guardar producto</button>
            <ValidationSummary class="text-danger mt-2" />
        </EditForm>
        @if (mensaje is not null)
        {
            <div class="alert @(error ? "alert-danger" : "alert-success") mt-3 mb-0">@mensaje</div>
        }
    </div>
</div>
}

@if (productos is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Filtrar por cliente</label>
            <select class="form-select" @bind="filtroClienteId">
                <option value="0">-- Todos los clientes --</option>
                @foreach (var c in clientes)
                {
                    <option value="@c.Id">@c.Nombre</option>
                }
            </select>
        </div>
    </div>

    <table class="table table-striped align-middle">
        <thead><tr><th>Código</th><th>Nombre</th><th>Cliente</th><th>Ubicación</th><th>Unidad</th>@if (puedeEditar){<th class="text-end" style="width:180px">Acciones</th>}</tr></thead>
        <tbody>
            @foreach (var p in productosFiltrados)
            {
                var item = p;
                @if (puedeEditar && editandoId == item.Id)
                {
                    <tr>
                        <td><input class="form-control form-control-sm" @bind="item.Codigo" /></td>
                        <td><input class="form-control form-control-sm" @bind="item.Nombre" /></td>
                        <td>@item.Cliente?.Nombre</td>
                        <td><input class="form-control form-control-sm" @bind="item.Ubicacion" placeholder="Ej. Pasillo 3 / Rack B" /></td>
                        <td><input class="form-control form-control-sm" @bind="item.UnidadMedida" /></td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-primary" @onclick="() => GuardarFilaAsync(item)" disabled="@guardando">
                                    <span class="bi bi-check-lg"></span> Guardar
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicion" disabled="@guardando">
                                    Cancelar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td><code>@item.Codigo</code></td>
                        <td>@item.Nombre</td>
                        <td>@item.Cliente?.Nombre</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Ubicacion) ? "—" : item.Ubicacion)</td>
                        <td>@item.UnidadMedida</td>
                        @if (puedeEditar)
                        {
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => editandoId = item.Id" disabled="@guardando">
                                        <span class="bi bi-pencil"></span> Editar
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAsync(item)" disabled="@guardando" title="Eliminar">
                                        <span class="bi bi-trash"></span>
                                    </button>
                                </div>
                            </td>
                        }
                    </tr>
                }
            }
            @if (!productosFiltrados.Any())
            {
                <tr><td colspan="@(puedeEditar ? 6 : 5)" class="text-center text-muted py-4">Sin productos.</td></tr>
            }
        </tbody>
    </table>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool puedeEditar;
    private List<Producto>? productos;
    private List<Cliente> clientes = [];
    private Producto nuevo = new();
    private string? mensaje;
    private bool error;
    private int filtroClienteId;
    private int? editandoId;
    private bool guardando;

    private IEnumerable<Producto> productosFiltrados =>
        filtroClienteId == 0
            ? (productos ?? [])
            : (productos ?? []).Where(p => p.ClienteId == filtroClienteId);

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        puedeEditar = user.PuedeEditarModulo(ModuloApp.Productos);
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        clientes = await db.Clientes.OrderBy(c => c.Nombre).ToListAsync();
        productos = await db.Productos.Include(p => p.Cliente).OrderBy(p => p.Nombre).ToListAsync();
    }

    private async Task GuardarAsync()
    {
        mensaje = null;
        error = false;
        if (nuevo.ClienteId == 0)
        {
            error = true;
            mensaje = "Debes seleccionar un cliente.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var duplicado = await db.Productos.AnyAsync(p => p.ClienteId == nuevo.ClienteId && p.Codigo == nuevo.Codigo);
        if (duplicado)
        {
            error = true;
            mensaje = "Ya existe un producto con ese código para ese cliente.";
            return;
        }

        db.Productos.Add(nuevo);
        await db.SaveChangesAsync();
        mensaje = $"Producto '{nuevo.Nombre}' guardado.";
        nuevo = new();
        await CargarAsync();
    }

    private void CancelarEdicion() => editandoId = null;

    private async Task GuardarFilaAsync(Producto p)
    {
        mensaje = null;
        error = false;
        if (string.IsNullOrWhiteSpace(p.Codigo) || string.IsNullOrWhiteSpace(p.Nombre))
        {
            error = true;
            mensaje = "El producto necesita código y nombre.";
            return;
        }

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var duplicado = await db.Productos.AnyAsync(x =>
                x.ClienteId == p.ClienteId && x.Codigo == p.Codigo && x.Id != p.Id);
            if (duplicado)
            {
                error = true;
                mensaje = "Ya existe otro producto con ese código para ese cliente.";
                return;
            }

            p.Codigo = p.Codigo.Trim();
            p.Nombre = p.Nombre.Trim();
            p.Ubicacion = string.IsNullOrWhiteSpace(p.Ubicacion) ? null : p.Ubicacion.Trim();
            db.Productos.Update(p);
            await db.SaveChangesAsync();
            mensaje = "Cambios guardados.";
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private async Task EliminarAsync(Producto p)
    {
        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Productos.Remove(p);
            await db.SaveChangesAsync();
            mensaje = $"Producto '{p.Nombre}' eliminado.";
            error = false;
            editandoId = null;
            await CargarAsync();
        }
        catch (DbUpdateException)
        {
            error = true;
            mensaje = "No se puede eliminar: el producto tiene movimientos (entradas/salidas) registrados.";
        }
        finally { guardando = false; }
    }
}
