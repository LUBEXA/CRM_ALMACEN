@page "/entradas"
@attribute [Authorize]
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Entradas - CRM Almacén</PageTitle>

<h1>📥 Entradas</h1>
<p class="text-muted">Mercancía que ingresa al almacén y suma existencia.</p>

@if (esAdmin)
{
    <div class="card mb-4">
        <div class="card-header">Registrar nueva entrada</div>
        <div class="card-body">
            <EditForm Model="nueva" OnValidSubmit="RegistrarAsync" FormName="formEntrada">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Cliente</label>
                        <InputSelect class="form-select" Value="clienteSeleccionado" ValueExpression="() => clienteSeleccionado" ValueChanged="(int v) => OnClienteChanged(v)">
                            <option value="0">-- Selecciona --</option>
                            @foreach (var c in clientes)
                            {
                                <option value="@c.Id">@c.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Producto</label>
                        <InputSelect class="form-select" @bind-Value="nueva.ProductoId" disabled="@(clienteSeleccionado == 0)">
                            <option value="0">@(clienteSeleccionado == 0 ? "-- Elige un cliente primero --" : "-- Selecciona --")</option>
                            @foreach (var p in productosFiltrados)
                            {
                                <option value="@p.Id">@p.Codigo — @p.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Cantidad</label>
                        <InputNumber class="form-control" @bind-Value="nueva.Cantidad" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Referencia</label>
                        <InputText class="form-control" @bind-Value="nueva.Referencia" placeholder="Remisión / factura" />
                    </div>
                    <div class="col-12 col-md-3">
                        <button type="submit" class="btn btn-success w-100" disabled="@(clienteSeleccionado == 0)">Registrar</button>
                    </div>
                    <div class="col-12">
                        <InputText class="form-control" @bind-Value="nueva.Observaciones" placeholder="Observaciones (opcional)" />
                    </div>
                </div>
                <ValidationSummary class="text-danger mt-2" />
            </EditForm>
            @if (mensaje is not null)
            {
                <div class="alert @(error ? "alert-danger" : "alert-success") mt-3 mb-0">@mensaje</div>
            }
        </div>
    </div>
}

@if (entradas is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Producto</th>
                    <th>Ubicación</th>
                    <th class="text-end">Cantidad</th>
                    <th>Referencia</th>
                    <th>Registró</th>
                    @if (esAdmin)
                    {
                        <th class="text-end" style="width:200px">Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var e in entradas)
                {
                    var item = e;
                    @if (esAdmin && editandoId == item.Id)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Producto?.Codigo — @item.Producto?.Nombre</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Producto?.Ubicacion) ? "—" : item.Producto!.Ubicacion)</td>
                            <td class="text-end">
                                <input type="number" min="1" class="form-control form-control-sm text-end" @bind="editCantidad" style="max-width:90px;display:inline-block" />
                            </td>
                            <td><input class="form-control form-control-sm" @bind="editReferencia" /></td>
                            <td class="small text-muted">@item.RegistradoPor</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-primary" @onclick="() => GuardarFilaAsync(item)" disabled="@guardando">
                                        <span class="bi bi-check-lg"></span> Guardar
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicion" disabled="@guardando">
                                        Cancelar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Producto?.Codigo — @item.Producto?.Nombre</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Producto?.Ubicacion) ? "—" : item.Producto!.Ubicacion)</td>
                            <td class="text-end fw-bold text-success">+@item.Cantidad</td>
                            <td>@item.Referencia</td>
                            <td class="small text-muted">@item.RegistradoPor</td>
                            @if (esAdmin)
                            {
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => IniciarEdicion(item)" disabled="@guardando">
                                            <span class="bi bi-pencil"></span> Editar
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAsync(item)" disabled="@guardando" title="Eliminar">
                                            <span class="bi bi-trash"></span>
                                        </button>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                }
                @if (entradas.Count == 0)
                {
                    <tr><td colspan="@(esAdmin ? 7 : 6)" class="text-center text-muted py-4">Sin entradas registradas.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private List<Entrada>? entradas;
    private List<Producto> productosDisponibles = [];
    private List<Cliente> clientes = [];
    private int clienteSeleccionado;
    private bool esAdmin;
    private int? clienteId;
    private string? usuario;
    private string? mensaje;
    private bool error;
    private bool guardando;
    private int? editandoId;
    private int editCantidad;
    private string? editReferencia;

    private IEnumerable<Producto> productosFiltrados =>
        productosDisponibles.Where(p => p.ClienteId == clienteSeleccionado);

    private void OnClienteChanged(int valor)
    {
        clienteSeleccionado = valor;
        nueva.ProductoId = 0;
    }

    private NuevaEntrada nueva = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        esAdmin = user.EsAdmin();
        clienteId = user.ClienteId();
        usuario = user.Identity?.Name;
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.Entradas.Include(e => e.Producto).ThenInclude(p => p!.Cliente).AsQueryable();
        if (clienteId is int id)
            query = query.Where(e => e.Producto!.ClienteId == id);

        entradas = await query.OrderByDescending(e => e.Fecha).Take(200).ToListAsync();

        if (esAdmin)
        {
            productosDisponibles = await db.Productos.Include(p => p.Cliente)
                .Where(p => p.Activo).OrderBy(p => p.Nombre).ToListAsync();
            clientes = await db.Clientes.OrderBy(c => c.Nombre).ToListAsync();
        }
    }

    private async Task RegistrarAsync()
    {
        mensaje = null;
        if (nueva.ProductoId == 0 || nueva.Cantidad <= 0)
            return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var producto = await db.Productos.FindAsync(nueva.ProductoId);
        if (producto is null) return;

        db.Entradas.Add(new Entrada
        {
            ProductoId = producto.Id,
            Cantidad = nueva.Cantidad,
            Referencia = nueva.Referencia,
            Observaciones = nueva.Observaciones,
            RegistradoPor = usuario,
            Fecha = DateTime.Now
        });
        producto.CantidadDisponible += nueva.Cantidad;
        await db.SaveChangesAsync();

        mensaje = $"Entrada registrada: +{nueva.Cantidad} de {producto.Nombre}.";
        nueva = new();
        await CargarAsync();
    }

    private void IniciarEdicion(Entrada e)
    {
        editandoId = e.Id;
        editCantidad = e.Cantidad;
        editReferencia = e.Referencia;
    }

    private void CancelarEdicion() => editandoId = null;

    private async Task GuardarFilaAsync(Entrada e)
    {
        mensaje = null;
        error = false;
        if (editCantidad <= 0)
        {
            error = true;
            mensaje = "La cantidad debe ser mayor a cero.";
            return;
        }

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entrada = await db.Entradas.FindAsync(e.Id);
            if (entrada is null) return;
            var producto = await db.Productos.FindAsync(entrada.ProductoId);
            if (producto is null) return;

            // La entrada suma existencia: más cantidad suma más, menos cantidad la resta.
            var delta = editCantidad - entrada.Cantidad;
            if (delta < 0 && (-delta) > producto.CantidadDisponible)
            {
                error = true;
                mensaje = $"No se puede reducir tanto: la existencia actual es {producto.CantidadDisponible}.";
                return;
            }

            producto.CantidadDisponible += delta;
            entrada.Cantidad = editCantidad;
            entrada.Referencia = editReferencia;
            await db.SaveChangesAsync();

            mensaje = "Entrada actualizada.";
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private async Task EliminarAsync(Entrada e)
    {
        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entrada = await db.Entradas.FindAsync(e.Id);
            if (entrada is null) return;
            var producto = await db.Productos.FindAsync(entrada.ProductoId);
            if (producto is not null)
            {
                if (entrada.Cantidad > producto.CantidadDisponible)
                {
                    error = true;
                    mensaje = $"No se puede eliminar: ya se usó parte de esa mercancía (existencia actual: {producto.CantidadDisponible}).";
                    return;
                }
                producto.CantidadDisponible -= entrada.Cantidad;
            }
            db.Entradas.Remove(entrada);
            await db.SaveChangesAsync();

            mensaje = $"Entrada eliminada. Se descontaron {e.Cantidad} de existencia.";
            error = false;
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private sealed class NuevaEntrada
    {
        public int ProductoId { get; set; }
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Cantidad debe ser mayor a 0.")]
        public int Cantidad { get; set; } = 1;
        public string? Referencia { get; set; }
        public string? Observaciones { get; set; }
    }
}
