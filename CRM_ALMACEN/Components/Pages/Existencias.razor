@page "/existencias"
@attribute [Authorize]
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Existencias - CRM Almacén</PageTitle>

<h1>📋 Existencias</h1>
<p class="text-muted">Inventario actual en el almacén.</p>

<div class="row mb-3">
    <div class="col-md-5">
        <input class="form-control" placeholder="Buscar por código o nombre..."
               @bind="filtro" @bind:event="oninput" />
    </div>
</div>

@if (mensaje is not null)
{
    <div class="alert @(error ? "alert-danger" : "alert-success")">@mensaje</div>
}

@if (productos is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    var lista = Filtrados().ToList();
    <p class="text-muted small">@lista.Count producto(s)</p>
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Producto</th>
                    @if (esAdmin)
                    {
                        <th>Cliente</th>
                    }
                    <th>Ubicación</th>
                    <th>Unidad</th>
                    <th class="text-end">Disponible</th>
                    <th>Estado</th>
                    @if (esAdmin)
                    {
                        <th class="text-end" style="width:200px">Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var p in lista)
                {
                    var item = p;
                    @if (esAdmin && editandoId == item.Id)
                    {
                        <tr>
                            <td><code>@item.Codigo</code></td>
                            <td>@item.Nombre</td>
                            <td>@item.Cliente?.Nombre</td>
                            <td><input class="form-control form-control-sm" @bind="item.Ubicacion" placeholder="Ej. Pasillo 3 / Rack B" /></td>
                            <td><input class="form-control form-control-sm" @bind="item.UnidadMedida" style="max-width:90px" /></td>
                            <td class="text-end">
                                <input type="number" min="0" class="form-control form-control-sm text-end" @bind="item.CantidadDisponible" style="max-width:90px;display:inline-block" />
                            </td>
                            <td></td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-primary" @onclick="() => GuardarFilaAsync(item)" disabled="@guardando">
                                        <span class="bi bi-check-lg"></span> Guardar
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicion" disabled="@guardando">
                                        Cancelar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td><code>@item.Codigo</code></td>
                            <td>@item.Nombre</td>
                            @if (esAdmin)
                            {
                                <td>@item.Cliente?.Nombre</td>
                            }
                            <td>@(string.IsNullOrWhiteSpace(item.Ubicacion) ? "—" : item.Ubicacion)</td>
                            <td>@item.UnidadMedida</td>
                            <td class="text-end fw-bold">@item.CantidadDisponible</td>
                            <td>
                                @if (item.CantidadDisponible <= item.StockMinimo)
                                {
                                    <span class="badge text-bg-danger">Bajo stock</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-success">OK</span>
                                }
                            </td>
                            @if (esAdmin)
                            {
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => editandoId = item.Id" disabled="@guardando">
                                            <span class="bi bi-pencil"></span> Editar
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAsync(item)" disabled="@guardando" title="Eliminar">
                                            <span class="bi bi-trash"></span>
                                        </button>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                }
                @if (lista.Count == 0)
                {
                    <tr><td colspan="@(esAdmin ? 8 : 6)" class="text-center text-muted py-4">Sin productos.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private List<Producto>? productos;
    private bool esAdmin;
    private int? clienteId;
    private string filtro = "";
    private int? editandoId;
    private bool guardando;
    private string? mensaje;
    private bool error;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        esAdmin = user.EsAdmin();
        clienteId = user.ClienteId();
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Productos.Include(p => p.Cliente).Where(p => p.Activo);
        if (clienteId is int id)
            query = query.Where(p => p.ClienteId == id);

        productos = await query.OrderBy(p => p.Nombre).ToListAsync();
    }

    private void CancelarEdicion()
    {
        editandoId = null;
        _ = CargarAsync();
    }

    private async Task GuardarFilaAsync(Producto p)
    {
        mensaje = null;
        error = false;
        if (p.CantidadDisponible < 0)
        {
            error = true;
            mensaje = "La existencia no puede ser negativa.";
            return;
        }

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            p.Ubicacion = string.IsNullOrWhiteSpace(p.Ubicacion) ? null : p.Ubicacion.Trim();
            p.UnidadMedida = string.IsNullOrWhiteSpace(p.UnidadMedida) ? "PZA" : p.UnidadMedida.Trim();
            db.Productos.Update(p);
            await db.SaveChangesAsync();
            mensaje = "Cambios guardados.";
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private async Task EliminarAsync(Producto p)
    {
        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Productos.Remove(p);
            await db.SaveChangesAsync();
            mensaje = $"Producto '{p.Nombre}' eliminado.";
            error = false;
            editandoId = null;
            await CargarAsync();
        }
        catch (DbUpdateException)
        {
            error = true;
            mensaje = "No se puede eliminar: el producto tiene movimientos (entradas/salidas) registrados.";
        }
        finally { guardando = false; }
    }

    private IEnumerable<Producto> Filtrados()
    {
        if (productos is null) return [];
        if (string.IsNullOrWhiteSpace(filtro)) return productos;
        var f = filtro.Trim();
        return productos.Where(p =>
            p.Codigo.Contains(f, StringComparison.OrdinalIgnoreCase) ||
            p.Nombre.Contains(f, StringComparison.OrdinalIgnoreCase));
    }
}
