    {
        EstadoSolicitud.Pendiente => "text-bg-warning",
        EstadoSolicitud.Aprobada => "text-bg-info",
        EstadoSolicitud.Surtida => "text-bg-success",
        EstadoSolicitud.Entregada => "text-bg-success",
        EstadoSolicitud.Rechazada => "text-bg-danger",
        EstadoSolicitud.Cancelada => "text-bg-secondary",
        _ => "text-bg-secondary"
    };

    private static string EstadoTexto(EstadoSolicitud e) => e switch
    {
        EstadoSolicitud.Pendiente => "Pendiente",
        EstadoSolicitud.Aprobada => "Aprobada",
        EstadoSolicitud.Surtida => "Surtida",
        EstadoSolicitud.Entregada => "Entregada",
        EstadoSolicitud.Rechazada => "Rechazada",
        EstadoSolicitud.Cancelada => "Cancelada",
        _ => e.ToString()
    };

    private void ToggleComentarios(int solicitudId)
    {
        if (!comentariosAbiertos.Remove(solicitudId))
            comentariosAbiertos.Add(solicitudId);
    }

    /// <summary>El cliente cancela un pedido propio que aún está Pendiente.</summary>
    private async Task CancelarAsync(int solicitudId)
    {
        errorAccion = null;
        var confirmar = await JS.InvokeAsync<bool>("confirm", "¿Seguro que deseas cancelar este pedido?");
        if (!confirmar) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var solicitud = await db.Solicitudes.FindAsync(solicitudId);
        if (solicitud is null) return;

        // Seguridad: solo el dueño puede cancelar y solo si sigue Pendiente.
        if (clienteId is int cid && solicitud.ClienteId != cid) return;
        if (solicitud.Estado != EstadoSolicitud.Pendiente)
        {
            errorAccion = "Este pedido ya no se puede cancelar.";
            return;
        }

        solicitud.Estado = EstadoSolicitud.Cancelada;
        solicitud.FechaAtencion = DateTime.Now;
        solicitud.AtendidoPor = usuario;
        await db.SaveChangesAsync();
        await CargarAsync();
    }

    /// <summary>Descarga el historial filtrado del cliente como archivo CSV (abre en Excel).</summary>
    private async Task DescargarExcelAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Solicitudes
            .Include(s => s.Detalles).ThenInclude(d => d.Producto)
            .AsQueryable();

        if (clienteId is int id) query = query.Where(s => s.ClienteId == id);
        if (filtroEstado != -2)
        {
            var estado = (EstadoSolicitud)filtroEstado;
            query = query.Where(s => s.Estado == estado);
        }
        if (!string.IsNullOrWhiteSpace(filtroBusqueda))
        {
            var digitos = new string(filtroBusqueda.Where(char.IsDigit).ToArray());
            if (int.TryParse(digitos, out var folioId))
                query = query.Where(s => s.Id == folioId);
        }
        if (filtroDesde is DateTime desde) query = query.Where(s => s.Fecha >= desde.Date);
        if (filtroHasta is DateTime hasta) query = query.Where(s => s.Fecha < hasta.Date.AddDays(1));

        var datos = await query.OrderByDescending(s => s.Fecha).ToListAsync();

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Fecha;Pedido;Cantidad x SKU;Estado");
        foreach (var s in datos)
        {
            var skus = string.Join(" | ", s.Detalles.Select(d => $"{d.Cantidad}x {d.Producto?.Nombre}"));
            sb.AppendLine($"{s.Fecha:dd/MM/yyyy HH:mm};{Folio(s)};{Csv(skus)};{EstadoTexto(s.Estado)}");
        }

        // BOM UTF-8 para que Excel respete los acentos.
        var bytes = System.Text.Encoding.UTF8.GetPreamble()
            .Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString())).ToArray();
        var b64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("descargarArchivo",
            $"historial-pedidos-{DateTime.Now:yyyyMMdd}.csv", b64, "text/csv");
    }

    /// <summary>Escapa un valor para CSV (separador ; con comillas si hace falta).</summary>
    private static string Csv(string? valor)
    {
        valor ??= "";
        if (valor.Contains(';') || valor.Contains('"') || valor.Contains('\n'))
            return $"\"{valor.Replace("\"", "\"\"")}\"";
        return valor;
    }

