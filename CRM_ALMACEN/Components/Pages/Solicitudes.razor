@page "/solicitudes"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.JSInterop
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Solicitudes de pedido - CRM Almacén</PageTitle>

<h1>📝 Solicitudes de pedido</h1>
<p class="text-muted">
    @(esAdmin
        ? "Solicitudes de los clientes pendientes de surtir."
        : "Pide al almacén que te surta mercancía.")
</p>

@* ---- Creación de pedido (solo Cliente): tabla de artículos + panel del pedido ---- *@
@if (!esAdmin && clienteId is not null)
{
    <div class="row g-3 mb-4">
        @* Izquierda: seleccionar artículos *@
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header fw-semibold">Seleccionar artículos</div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-7">
                            <input class="form-control" placeholder="Buscar modelo / SKU"
                                   @bind="busquedaProducto" @bind:event="oninput" />
                        </div>
                        <div class="col-md-5">
                            <button class="btn btn-outline-primary w-100" @onclick="AgregarSeleccionAlPedido">
                                + Agregar al pedido
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Modelo / SKU</th>
                                    <th class="text-end" style="width:120px">Disponible</th>
                                    <th class="text-center" style="width:130px">Cant. Pedido</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in ProductosFiltradosCliente)
                                {
                                    <tr>
                                        <td>@p.Codigo — @p.Nombre</td>
                                        <td class="text-end">@p.CantidadDisponible</td>
                                        <td class="text-center">
                                            <input type="number" min="0" max="@p.CantidadDisponible"
                                                   class="form-control form-control-sm text-center"
                                                   value="@CantidadDe(p.Id)"
                                                   @onchange="(e) => SetCantidad(p.Id, e)" />
                                        </td>
                                    </tr>
                                }
                                @if (!ProductosFiltradosCliente.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-3">No hay artículos.</td></tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold">
                                    <td>Total</td>
                                    <td class="text-end">@ProductosFiltradosCliente.Sum(p => p.CantidadDisponible)</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* Derecha: pedido creado *@
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">Pedido creado</div>
                <div class="card-body d-flex flex-column">
                    <p class="mb-2">Artículos en el pedido: <strong>@renglones.Count</strong></p>

                    @if (renglones.Count > 0)
                    {
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var r in renglones)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <span class="small">@r.Nombre</span>
                                    <span>
                                        <span class="badge text-bg-secondary me-2">@r.Cantidad</span>
                                        <button class="btn btn-sm btn-outline-danger py-0" @onclick="() => QuitarRenglon(r)">×</button>
                                    </span>
                                </li>
                            }
                        </ul>
                        <textarea class="form-control mb-2" placeholder="Notas (opcional)" @bind="notas"></textarea>
                        <button class="btn btn-primary mt-auto" @onclick="EnviarSolicitudAsync">
                            Finalizar y enviar solicitud
                        </button>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">
                            Captura cantidades en la tabla de la izquierda y presiona <strong>Agregar al pedido</strong>.
                        </p>
                    }

                    @if (mensaje is not null)
                    {
                        <div class="alert alert-success mt-3 mb-0">@mensaje</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ---- Filtros y búsqueda ---- *@
<div class="card mb-3">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            @if (esAdmin)
            {
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Estado</label>
                    <select class="form-select form-select-sm" @bind="filtroEstado" @bind:after="AplicarFiltrosAsync">
                        <option value="-2">Todos</option>
                        <option value="0">Pendiente (lista de espera)</option>
                        <option value="2">Surtida</option>
                        <option value="4">Entregada</option>
                        <option value="3">Rechazada</option>
                    </select>
                </div>
                <div class="col-6 col-md-4">
                    <label class="form-label small mb-1">Cliente</label>
                    <select class="form-select form-select-sm" @bind="filtroClienteId" @bind:after="AplicarFiltrosAsync">
                        <option value="0">Todos los clientes</option>
                        @foreach (var c in clientes)
                        {
                            <option value="@c.Id">@c.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-8 col-md-3">
                    <label class="form-label small mb-1">Buscar por folio o cliente</label>
                    <input class="form-control form-control-sm" placeholder="Ej. SOL-00012 o un nombre" @bind="filtroBusqueda" @bind:after="AplicarFiltrosAsync" />
                </div>
            }
            else
            {
                @* ---- Filtros del cliente para el Historial de pedidos ---- *@
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Buscar folio</label>
                    <input class="form-control form-control-sm" placeholder="Ej. SOL-00012" @bind="filtroBusqueda" @bind:after="AplicarFiltrosAsync" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small mb-1">Estado</label>
                    <select class="form-select form-select-sm" @bind="filtroEstado" @bind:after="AplicarFiltrosAsync">
                        <option value="-2">Todos los estados</option>
                        <option value="0">Pendiente</option>
                        <option value="2">Surtida</option>
                        <option value="4">Entregada</option>
                        <option value="3">Rechazada</option>
                        <option value="5">Cancelada</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small mb-1">Desde</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtroDesde" @bind:after="AplicarFiltrosAsync" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small mb-1">Hasta</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtroHasta" @bind:after="AplicarFiltrosAsync" />
                </div>
            }
            <div class="col-4 col-md-2 text-md-end">
                <label class="form-label small mb-1 d-none d-md-block">&nbsp;</label>
                <span class="badge text-bg-secondary">@totalRegistros pedido(s)</span>
            </div>
        </div>
    </div>
</div>

@* ---- Listado ---- *@
@if (solicitudes is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <h2 class="h5 mb-3">📋 Historial de pedidos</h2>

    @if (!esAdmin)
    {
        <div class="mb-3">
            <button class="btn btn-success btn-sm" @onclick="DescargarExcelAsync">
                📊 Descargar en Excel
            </button>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Pedido</th>
                        <th>Cant. x SKU</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in solicitudes)
                    {
                        <tr>
                            <td class="small text-nowrap">@s.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge text-bg-dark font-monospace">@Folio(s)</span></td>
                            <td>
                                @foreach (var d in s.Detalles)
                                {
                                    <div class="small">@d.Cantidad x @d.Producto?.Nombre</div>
                                }
                            </td>
                            <td><span class="badge @EstadoColor(s.Estado)">@EstadoTexto(s.Estado)</span></td>
                            <td class="text-end text-nowrap">
                                @if (s.Estado == EstadoSolicitud.Pendiente)
                                {
                                    <button class="btn btn-sm btn-outline-danger mb-1" @onclick="() => CancelarAsync(s.Id)">Cancelar</button>
                                }
                                <button class="btn btn-sm btn-outline-primary mb-1" @onclick="() => ToggleComentarios(s.Id)">Ver comentarios</button>
                            </td>
                        </tr>
                        @if (comentariosAbiertos.Contains(s.Id))
                        {
                            <tr class="table-active">
                                <td colspan="5" class="small">
                                    <strong>Comentarios / notas:</strong>
                                    @(string.IsNullOrWhiteSpace(s.Notas) ? " Sin comentarios." : $" {s.Notas}")
                                </td>
                            </tr>
                        }
                    }
                    @if (solicitudes.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No tienes pedidos con los filtros seleccionados.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
    @foreach (var s in solicitudes)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-1">
                <span>
                    <span class="badge text-bg-dark font-monospace me-1">@Folio(s)</span>
                    <span class="text-muted small">@s.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                    @if (esAdmin)
                    {
                        <span class="ms-2 fw-semibold">@s.Cliente?.Nombre</span>
                    }
                </span>
                <span class="badge @EstadoColor(s.Estado)">@s.Estado</span>
            </div>
            <div class="card-body">
                <ul class="mb-2">
                    @foreach (var d in s.Detalles)
                    {
                        <li>@d.Producto?.Codigo — @d.Producto?.Nombre: <strong>@d.Cantidad</strong></li>
                    }
                </ul>
                @if (!string.IsNullOrWhiteSpace(s.Notas))
                {
                    <p class="text-muted small mb-2">Notas: @s.Notas</p>
                }

                @if (esAdmin && s.Estado == EstadoSolicitud.Pendiente)
                {
                    var sinCobros = CobrosDe(s.Id).Count == 0;
                    <button class="btn btn-sm btn-success me-2" @onclick="() => SurtirAsync(s.Id)" disabled="@sinCobros">Aprobar y surtir</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RechazarAsync(s.Id)">Rechazar</button>
                    @if (sinCobros)
                    {
                        <span class="text-danger small ms-2">
                            <span class="bi bi-exclamation-triangle"></span>
                            Agrega los cobros antes de surtir.
                        </span>
                    }
                }

                @* ---- Cobros del pedido (solo administrador) ---- *@
                @if (esAdmin)
                {
                    var cobros = CobrosDe(s.Id);
                    var tarifario = TarifarioDe(s.ClienteId);
                    var nuevo = NuevoCobroDe(s.Id);
                    <details class="border-top mt-3 pt-3">
                        <summary class="text-primary fw-semibold mb-2" style="cursor:pointer">
                            <span class="bi bi-cash-coin"></span> Cobros de este pedido (@cobros.Count)
                            <span class="text-muted small fw-normal">— estado de cuenta de @NombresMes.Get(s.Fecha.Month) @s.Fecha.Year</span>
                        </summary>

                        <div class="table-responsive mt-2">
                            <table class="table table-sm align-middle mb-2">
                                <thead>
                                    <tr>
                                        <th>Concepto</th>
                                        <th class="text-center" style="width:90px">Cantidad</th>
                                        <th class="text-end" style="width:150px">Precio unitario</th>
                                        <th class="text-end" style="width:130px">Importe</th>
                                        <th style="width:48px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in cobros)
                                    {
                                        <tr>
                                            <td><input class="form-control form-control-sm" @bind="c.Concepto" /></td>
                                            <td><input type="number" min="1" class="form-control form-control-sm text-center" @bind="c.Cantidad" @bind:after="() => RecalcularCargo(c)" /></td>
                                            <td>
                                                <div class="input-group input-group-sm">
                                                    <span class="input-group-text">$</span>
                                                    <input type="number" step="0.01" class="form-control text-end" @bind="c.PrecioUnitario" @bind:after="() => RecalcularCargo(c)" />
                                                </div>
                                            </td>
                                            <td class="text-end fw-semibold">@Money(c.Monto)</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarCobroAsync(c.Id, s.Id)" title="Quitar cobro"><span class="bi bi-trash"></span></button>
                                            </td>
                                        </tr>
                                    }
                                    @if (cobros.Count == 0)
                                    {
                                        <tr><td colspan="5" class="text-center text-muted py-2">Aún no hay cobros para este pedido.</td></tr>
                                    }
                                </tbody>
                                @if (cobros.Count > 0)
                                {
                                    <tfoot>
                                        <tr>
                                            <td class="fw-bold" colspan="3">Total a cobrar</td>
                                            <td class="text-end fw-bold">@Money(cobros.Sum(c => c.Monto))</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                }
                            </table>
                        </div>

                        @* Fila para agregar un cobro: desde el tarifario o uno adicional *@
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small mb-1">Servicio contratado</label>
                                <select class="form-select form-select-sm" value="0" @onchange="(e) => SeleccionarTarifario(s.Id, e)">
                                    <option value="0">-- Concepto adicional (manual) --</option>
                                    @foreach (var t in tarifario)
                                    {
                                        <option value="@t.Id">@t.Concepto — @Money(t.ImporteNeto)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small mb-1">Concepto</label>
                                <input class="form-control form-control-sm" @bind="nuevo.Concepto" placeholder="Ej. Maniobra extra" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small mb-1">Cantidad</label>
                                <input type="number" min="1" class="form-control form-control-sm" @bind="nuevo.Cantidad" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small mb-1">Precio unitario</label>
                                <input type="number" step="0.01" class="form-control form-control-sm" @bind="nuevo.PrecioUnitario" />
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-sm btn-success w-100" @onclick="() => AgregarCobroAsync(s)" disabled="@procesando">+</button>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-2 align-items-center">
                            @if (cobros.Count > 0)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="() => GuardarCobrosAsync(s.Id)" disabled="@procesando">
                                    <span class="bi bi-save"></span> Guardar cambios
                                </button>
                                <a class="btn btn-sm btn-outline-secondary" href="/pagos">Ver en estado de cuenta</a>
                            }
                            @if (mensajeCobro.TryGetValue(s.Id, out var msg) && msg is not null)
                            {
                                <span class="text-success small">@msg</span>
                            }
                        </div>
                    </details>
                }
            </div>
        </div>
    }
    @if (solicitudes.Count == 0)
    {
        <p class="text-muted">No hay pedidos con los filtros seleccionados.</p>
    }
    }
    @if (errorAccion is not null)
    {
        <div class="alert alert-danger">@errorAccion</div>
    }

    @if (TotalPaginas > 1)
    {
        <nav class="d-flex justify-content-between align-items-center mt-3 mb-4">
            <button class="btn btn-sm btn-outline-secondary" disabled="@(pagina <= 1)" @onclick="PaginaAnteriorAsync">← Anteriores</button>
            <span class="text-muted small">Página @pagina de @TotalPaginas</span>
            <button class="btn btn-sm btn-outline-secondary" disabled="@(pagina >= TotalPaginas)" @onclick="PaginaSiguienteAsync">Siguientes →</button>
        </nav>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private List<SolicitudPedido>? solicitudes;
    private List<Producto> misProductos = [];
    private List<Cliente> clientes = [];
    private bool esAdmin;
    private int? clienteId;
    private string? usuario;

    // Filtros y paginación (lista de espera escalable).
    private int filtroEstado;          // -2 = todos; si no, valor del enum EstadoSolicitud
    private int filtroClienteId;       // 0 = todos los clientes (solo admin)
    private string filtroBusqueda = "";
    private DateTime? filtroDesde;     // rango de fechas (Historial del cliente)
    private DateTime? filtroHasta;
    private readonly HashSet<int> comentariosAbiertos = [];   // pedidos con comentarios desplegados
    private int pagina = 1;
    private const int PorPagina = 8;
    private int totalRegistros;
    private int TotalPaginas => totalRegistros == 0 ? 1 : (int)Math.Ceiling(totalRegistros / (double)PorPagina);

    /// <summary>Folio único e irrepetible del pedido (basado en su Id).</summary>
    private static string Folio(SolicitudPedido s) => Folio(s.Id);
    private static string Folio(int solicitudId) => $"SOL-{solicitudId:00000}";

    // Builder de la nueva solicitud (cliente)
    private string busquedaProducto = "";
    private readonly Dictionary<int, int> cantidades = [];
    private string? notas;
    private readonly List<Renglon> renglones = [];

    private IEnumerable<Producto> ProductosFiltradosCliente =>
        string.IsNullOrWhiteSpace(busquedaProducto)
            ? misProductos
            : misProductos.Where(p =>
                (p.Nombre?.Contains(busquedaProducto, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Codigo?.Contains(busquedaProducto, StringComparison.OrdinalIgnoreCase) ?? false));

    private int CantidadDe(int productoId) =>
        cantidades.TryGetValue(productoId, out var c) ? c : 0;

    private void SetCantidad(int productoId, ChangeEventArgs e)
    {
        var prod = misProductos.FirstOrDefault(p => p.Id == productoId);
        if (!int.TryParse(e.Value?.ToString(), out var valor) || valor < 0) valor = 0;
        if (prod is not null && valor > prod.CantidadDisponible) valor = prod.CantidadDisponible;
        cantidades[productoId] = valor;
    }

    /// <summary>Pasa las cantidades capturadas en la tabla al pedido (renglones).</summary>
    private void AgregarSeleccionAlPedido()
    {
        foreach (var (productoId, cantidad) in cantidades)
        {
            if (cantidad <= 0) continue;
            var prod = misProductos.FirstOrDefault(p => p.Id == productoId);
            if (prod is null) continue;

            var existente = renglones.FirstOrDefault(r => r.ProductoId == productoId);
            if (existente is not null)
                existente.Cantidad = cantidad;
            else
                renglones.Add(new Renglon { ProductoId = productoId, Nombre = $"{prod.Codigo} — {prod.Nombre}", Cantidad = cantidad });
        }
        cantidades.Clear();
        mensaje = null;
    }
    private string? mensaje;
    private string? errorAccion;
    private bool procesando;

    // Cobros (Cargos) por solicitud, tarifario por cliente y formularios de nuevo cobro.
    private Dictionary<int, List<Cargo>> cobrosPorSolicitud = [];
    private Dictionary<int, List<CostoServicio>> tarifarioPorCliente = [];
    private readonly Dictionary<int, Cargo> nuevoCobroPorSolicitud = [];
    private readonly Dictionary<int, string?> mensajeCobro = [];

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        esAdmin = user.EsAdmin();
        clienteId = user.ClienteId();
        usuario = user.Identity?.Name;

        // El cliente ve su historial completo por defecto (todos los estados).
        if (!esAdmin) filtroEstado = -2;

        if (esAdmin)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            clientes = await db.Clientes.OrderBy(c => c.Nombre).ToListAsync();
        }

        await CargarAsync();
    }

    private async Task AplicarFiltrosAsync()
    {
        pagina = 1;
        await CargarAsync();
    }

    private async Task PaginaAnteriorAsync()
    {
        if (pagina <= 1) return;
        pagina--;
        await CargarAsync();
    }

    private async Task PaginaSiguienteAsync()
    {
        if (pagina >= TotalPaginas) return;
        pagina++;
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.Solicitudes
            .Include(s => s.Cliente)
            .Include(s => s.Detalles).ThenInclude(d => d.Producto)
            .AsQueryable();

        // El cliente solo ve lo suyo; el admin puede filtrar por cliente.
        if (clienteId is int id)
            query = query.Where(s => s.ClienteId == id);
        else if (filtroClienteId > 0)
            query = query.Where(s => s.ClienteId == filtroClienteId);

        // Filtro por estado (-2 = todos).
        if (filtroEstado != -2)
        {
            var estado = (EstadoSolicitud)filtroEstado;
            query = query.Where(s => s.Estado == estado);
        }

        // Búsqueda por folio (Id) para todos; por nombre de cliente solo admin.
        if (!string.IsNullOrWhiteSpace(filtroBusqueda))
        {
            var texto = filtroBusqueda.Trim();
            var digitos = new string(texto.Where(char.IsDigit).ToArray());
            if (int.TryParse(digitos, out var folioId))
            {
                if (esAdmin)
                    query = query.Where(s => s.Id == folioId || EF.Functions.ILike(s.Cliente!.Nombre, $"%{texto}%"));
                else
                    query = query.Where(s => s.Id == folioId);
            }
            else if (esAdmin)
                query = query.Where(s => EF.Functions.ILike(s.Cliente!.Nombre, $"%{texto}%"));
        }

        // Rango de fechas (Historial del cliente; el admin no muestra estos campos).
        if (filtroDesde is DateTime desde)
            query = query.Where(s => s.Fecha >= desde.Date);
        if (filtroHasta is DateTime hasta)
            query = query.Where(s => s.Fecha < hasta.Date.AddDays(1));

        totalRegistros = await query.CountAsync();

        // Ajustar la página si quedó fuera de rango (p. ej. tras filtrar).
        if (pagina > TotalPaginas) pagina = TotalPaginas;
        if (pagina < 1) pagina = 1;

        solicitudes = await query
            .OrderByDescending(s => s.Fecha)
            .Skip((pagina - 1) * PorPagina)
            .Take(PorPagina)
            .ToListAsync();

        if (clienteId is int cid)
            misProductos = await db.Productos.Where(p => p.Activo && p.ClienteId == cid)
                .OrderBy(p => p.Nombre).ToListAsync();

        if (esAdmin)
        {
            var ids = solicitudes.Select(s => s.Id).ToList();
            cobrosPorSolicitud = (await db.Cargos
                    .Where(c => c.SolicitudPedidoId != null && ids.Contains(c.SolicitudPedidoId!.Value))
                    .OrderBy(c => c.Id).ToListAsync())
                .GroupBy(c => c.SolicitudPedidoId!.Value)
                .ToDictionary(g => g.Key, g => g.ToList());

            var clienteIds = solicitudes.Select(s => s.ClienteId).Distinct().ToList();
            tarifarioPorCliente = (await db.CostosServicio
                    .Where(c => clienteIds.Contains(c.ClienteId))
                    .OrderBy(c => c.Concepto).ToListAsync())
                .GroupBy(c => c.ClienteId)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
    }

    private List<Cargo> CobrosDe(int solicitudId) =>
        cobrosPorSolicitud.TryGetValue(solicitudId, out var lista) ? lista : [];

    private List<CostoServicio> TarifarioDe(int clienteId) =>
        tarifarioPorCliente.TryGetValue(clienteId, out var lista) ? lista : [];

    private Cargo NuevoCobroDe(int solicitudId)
    {
        if (!nuevoCobroPorSolicitud.TryGetValue(solicitudId, out var c))
        {
            c = new Cargo { Cantidad = 1 };
            nuevoCobroPorSolicitud[solicitudId] = c;
        }
        return c;
    }

    private void SeleccionarTarifario(int solicitudId, ChangeEventArgs e)
    {
        var nuevo = NuevoCobroDe(solicitudId);
        if (int.TryParse(e.Value?.ToString(), out var tid) && tid > 0)
        {
            var sol = solicitudes?.FirstOrDefault(s => s.Id == solicitudId);
            var t = sol is null ? null : TarifarioDe(sol.ClienteId).FirstOrDefault(x => x.Id == tid);
            if (t is not null)
            {
                nuevo.Concepto = t.Concepto;
                nuevo.PrecioUnitario = t.ImporteNeto;
                if (nuevo.Cantidad < 1) nuevo.Cantidad = 1;
            }
        }
    }

    private async Task AgregarCobroAsync(SolicitudPedido s)
    {
        var nuevo = NuevoCobroDe(s.Id);
        if (string.IsNullOrWhiteSpace(nuevo.Concepto)) return;
        procesando = true;
        try
        {
            nuevo.Cantidad = nuevo.Cantidad < 1 ? 1 : nuevo.Cantidad;
            RecalcularCargo(nuevo);

            await using var db = await DbFactory.CreateDbContextAsync();
            db.Cargos.Add(new Cargo
            {
                ClienteId = s.ClienteId,
                SolicitudPedidoId = s.Id,
                Anio = s.Fecha.Year,
                Mes = s.Fecha.Month,
                Concepto = nuevo.Concepto.Trim(),
                Tipo = TipoCargo.Servicio,
                Cantidad = nuevo.Cantidad,
                PrecioUnitario = nuevo.PrecioUnitario,
                Monto = nuevo.Monto
            });
            await db.SaveChangesAsync();

            nuevoCobroPorSolicitud[s.Id] = new Cargo { Cantidad = 1 };
            mensajeCobro[s.Id] = "Cobro agregado al estado de cuenta.";
            await CargarAsync();
        }
        finally { procesando = false; }
    }

    private async Task GuardarCobrosAsync(int solicitudId)
    {
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach (var c in CobrosDe(solicitudId))
            {
                c.Concepto = c.Concepto.Trim();
                RecalcularCargo(c);
                db.Cargos.Update(c);
            }
            await db.SaveChangesAsync();
            mensajeCobro[solicitudId] = "Cambios guardados.";
        }
        finally { procesando = false; }
    }

    private async Task EliminarCobroAsync(int cargoId, int solicitudId)
    {
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var cargo = await db.Cargos.FindAsync(cargoId);
            if (cargo is not null)
            {
                db.Cargos.Remove(cargo);
                await db.SaveChangesAsync();
            }
            mensajeCobro[solicitudId] = "Cobro eliminado.";
            await CargarAsync();
        }
        finally { procesando = false; }
    }

    /// <summary>Recalcula el importe del cobro: Cantidad × Precio unitario.</summary>
    private static void RecalcularCargo(Cargo c)
    {
        if (c.Cantidad < 1) c.Cantidad = 1;
        c.Monto = c.Cantidad * c.PrecioUnitario;
    }

    private static string Money(decimal m) => $"${m:N2} MXN";

    private void QuitarRenglon(Renglon r) => renglones.Remove(r);

    private async Task EnviarSolicitudAsync()
    {
        if (renglones.Count == 0 || clienteId is null) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var solicitud = new SolicitudPedido
        {
            ClienteId = clienteId.Value,
            Fecha = DateTime.Now,
            Estado = EstadoSolicitud.Pendiente,
            Notas = notas,
            SolicitadoPor = usuario,
            Detalles = renglones.Select(r => new DetalleSolicitud
            {
                ProductoId = r.ProductoId,
                Cantidad = r.Cantidad
            }).ToList()
        };
        db.Solicitudes.Add(solicitud);
        await db.SaveChangesAsync();

        mensaje = $"Solicitud enviada con {renglones.Count} producto(s).";
        renglones.Clear();
        notas = null;
        await CargarAsync();
    }

    private async Task SurtirAsync(int solicitudId)
    {
        errorAccion = null;

        // No se puede surtir si el pedido aún no tiene cobros capturados.
        if (CobrosDe(solicitudId).Count == 0)
        {
            errorAccion = $"No puedes surtir el pedido {Folio(solicitudId)} sin agregar al menos un cobro. " +
                          "Abre «Cobros de este pedido» y registra los conceptos antes de continuar.";
            await JS.InvokeVoidAsync("alert", errorAccion);
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var solicitud = await db.Solicitudes.Include(s => s.Detalles).ThenInclude(d => d.Producto)
            .FirstOrDefaultAsync(s => s.Id == solicitudId);
        if (solicitud is null || solicitud.Estado != EstadoSolicitud.Pendiente) return;

        // Validar existencia de todos los renglones
        foreach (var d in solicitud.Detalles)
        {
            if (d.Producto is null || d.Cantidad > d.Producto.CantidadDisponible)
            {
                errorAccion = $"No se puede surtir: existencia insuficiente de {d.Producto?.Nombre}.";
                return;
            }
        }

        // Generar salidas y descontar
        foreach (var d in solicitud.Detalles)
        {
            db.Salidas.Add(new Salida
            {
                ProductoId = d.ProductoId,
                Cantidad = d.Cantidad,
                Referencia = Folio(solicitud),
                SolicitudPedidoId = solicitud.Id,
                RegistradoPor = usuario,
                Fecha = DateTime.Now
            });
            d.Producto!.CantidadDisponible -= d.Cantidad;
        }
        solicitud.Estado = EstadoSolicitud.Surtida;
        solicitud.FechaAtencion = DateTime.Now;
        solicitud.AtendidoPor = usuario;
        await db.SaveChangesAsync();
        await CargarAsync();
    }

    private async Task RechazarAsync(int solicitudId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var solicitud = await db.Solicitudes.FindAsync(solicitudId);
        if (solicitud is null) return;
        solicitud.Estado = EstadoSolicitud.Rechazada;
        solicitud.FechaAtencion = DateTime.Now;
        solicitud.AtendidoPor = usuario;
        await db.SaveChangesAsync();
        await CargarAsync();
    }

