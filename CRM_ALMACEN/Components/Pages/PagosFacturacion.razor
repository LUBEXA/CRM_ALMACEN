    private async Task AgregarPagoAsync()
    {
        if (clienteId is not int id || nuevoPago.Monto <= 0) return;
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Pagos.Add(new Pago
            {
                ClienteId = id,
                Anio = PeriodoAnio,
                Mes = PeriodoMes,
                Fecha = nuevoPago.Fecha,
                Monto = nuevoPago.Monto,
                MetodoPago = nuevoPago.MetodoPago,
                Referencia = nuevoPago.Referencia,
                XmlArchivo = nuevoPago.XmlArchivo,
                PdfArchivo = nuevoPago.PdfArchivo,
                RegistradoPor = usuario
            });
            await db.SaveChangesAsync();
            mensajePago = "Pago registrado.";
            nuevoPago = new() { Fecha = DateTime.Now };
            await CargarPeriodosAsync(id);
            await CargarPeriodoAsync();
        }
        finally { procesando = false; }
    }

    private async Task GuardarCambiosPagosAsync()
    {
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach (var p in pagosPeriodo)
                db.Pagos.Update(p);
            await db.SaveChangesAsync();
            mensajePago = "Cambios guardados.";
            if (clienteId is int id) await CargarPeriodosAsync(id);
        }
        finally { procesando = false; }
    }

