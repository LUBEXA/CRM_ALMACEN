@page "/pagos"
@attribute [Authorize(Policy = "Ver:Pagos")]
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AlmacenamientoArchivos Almacenamiento

<PageTitle>Pagos y Facturación - CRM Almacén</PageTitle>

<h1>Pagos y Facturación</h1>

@if (esAdmin)
{
    <div class="card mb-3">
        <div class="card-body">
            <label class="form-label">Cliente</label>
            <select class="form-select" style="max-width:420px" @bind="clienteSeleccionado" @bind:after="CambiarClienteAsync">
                <option value="0">-- Selecciona un cliente --</option>
                @foreach (var c in clientes)
                {
                    <option value="@c.Id">@c.Nombre</option>
                }
            </select>
        </div>
    </div>
}

@if (cargando)
{
    <p><em>Cargando...</em></p>
}
else if (clienteId is null)
{
    <div class="alert alert-info">Selecciona un cliente para ver sus pagos.</div>
}
else
{
    @* ---------- Selector de periodo ---------- *@
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <label class="form-label mb-0 fw-semibold">Periodo:</label>
        <select class="form-select" style="max-width:240px" @bind="periodoKey" @bind:after="CargarPeriodoAsync">
            @foreach (var p in periodos)
            {
                <option value="@(p.Anio * 100 + p.Mes)">@NombresMes.Get(p.Mes) @p.Anio</option>
            }
        </select>
    </div>

    @* ---------- Estado de cuenta del periodo ---------- *@
    <div class="card mb-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <h5 class="text-primary mb-0">Estado de cuenta <span class="text-muted fs-6">— @NombresMes.Get(PeriodoMes) @PeriodoAnio</span></h5>
                @if (puedeEditar || Liberado)
                {
                    <span class="badge fs-6 @EstadoClase">@EstadoTexto</span>
                }
                else
                {
                    <span class="badge fs-6 text-bg-secondary">En preparación</span>
                }
            </div>

            @* ---------- Corte de facturación y liberación al cliente ---------- *@
            @if (puedeEditar)
            {
                <div class="border rounded p-3 mb-3 @(Liberado ? "bg-success-subtle" : "bg-light-subtle")">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Fecha de corte</label>
                            <input type="date" class="form-control form-control-sm" @bind="fechaCorteEdit" />
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-sm btn-outline-secondary w-100" @onclick="GuardarFechaCorteAsync" disabled="@procesando">
                                <span class="bi bi-calendar-check"></span> Guardar fecha
                            </button>
                        </div>
                        <div class="col-md-5">
                            @if (Liberado)
                            {
                                <button class="btn btn-sm btn-outline-danger w-100" @onclick="() => LiberarAsync(false)" disabled="@procesando">
                                    <span class="bi bi-eye-slash"></span> Ocultar al cliente
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success w-100" @onclick="() => LiberarAsync(true)" disabled="@procesando">
                                    <span class="bi bi-unlock"></span> Liberar total al cliente
                                </button>
                            }
                        </div>
                    </div>
                    <p class="small mb-0 mt-2 @(Liberado ? "text-success" : "text-muted")">
                        @if (Liberado)
                        {
                            <span class="bi bi-check-circle"></span>
                            <text> Liberado al cliente</text>
                            @if (corte?.LiberadoEn is DateTime le) { <text> el @le.ToString("dd/MM/yyyy HH:mm")</text>; }
                            <text>. Ya puede ver su estado de cuenta.</text>
                        }
                        else
                        {
                            <span class="bi bi-info-circle"></span>
                            <text> El cliente NO ve este estado de cuenta hasta que presiones «Liberar total al cliente».</text>
                        }
                    </p>
                </div>
            }
            else if (Liberado && corte?.FechaCorte is DateTime fcCli)
            {
                <p class="text-muted small mb-2"><span class="bi bi-calendar-check"></span> Estado de cuenta al corte del @fcCli.ToString("dd/MM/yyyy").</p>
            }

            @if (!puedeEditar && !Liberado)
            {
                <div class="alert alert-info mb-0">
                    <span class="bi bi-hourglass-split"></span>
                    Tu estado de cuenta de este periodo aún está en preparación. Estará disponible en cuanto el administrador establezca la fecha de corte y lo libere.
                </div>
            }
            else
            {
            <p class="text-muted small">Esto es lo que incluye tu servicio en este periodo:</p>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Concepto</th>
                            @if (puedeEditar) { <th style="min-width:140px">Tipo</th> }
                            <th class="text-center">Cantidad</th>
                            @if (puedeEditar) { <th class="text-end" style="min-width:140px">Precio unitario</th> }
                            <th class="text-end">Importe</th>
                            @if (puedeEditar) { <th></th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in cargosPeriodo)
                        {
                            <tr>
                                @if (puedeEditar)
                                {
                                    <td><input class="form-control form-control-sm" @bind="c.Concepto" /></td>
                                    <td>
                                        <select class="form-select form-select-sm" @bind="c.Tipo" @bind:after="() => RecalcularCargo(c)">
                                            @foreach (var t in Enum.GetValues<TipoCargo>())
                                            {
                                                <option value="@t">@TipoTexto(t)</option>
                                            }
                                        </select>
                                    </td>
                                    <td style="max-width:100px"><input type="number" min="1" class="form-control form-control-sm text-center" @bind="c.Cantidad" @bind:after="() => RecalcularCargo(c)" /></td>
                                    <td style="max-width:160px">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">$</span>
                                            <input type="number" step="0.01" class="form-control text-end" @bind="c.PrecioUnitario" @bind:after="() => RecalcularCargo(c)" />
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold @(c.Monto < 0 ? "text-success" : "")">@Money(c.Monto)</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarCargoAsync(c.Id)" title="Eliminar">
                                            <span class="bi bi-trash"></span>
                                        </button>
                                    </td>
                                }
                                else
                                {
                                    <td>
                                        @c.Concepto
                                        @if (c.Tipo != TipoCargo.Servicio)
                                        {
                                            <span class="badge text-bg-light text-muted ms-1">@c.TipoTexto</span>
                                        }
                                    </td>
                                    <td class="text-center">@c.Cantidad</td>
                                    <td class="text-end @(c.Monto < 0 ? "text-success" : "")">@Money(c.Monto)</td>
                                }
                            </tr>
                        }
                        @if (cargosPeriodo.Count == 0)
                        {
                            <tr><td colspan="@(puedeEditar ? 6 : 3)" class="text-center text-muted py-3">Sin cargos en este periodo.</td></tr>
                        }
                    </tbody>
                    @if (cargosPeriodo.Count > 0)
                    {
                        <tfoot>
                            <tr class="periodo-total">
                                <td class="fw-bold" colspan="@(puedeEditar ? 4 : 2)">Total del periodo</td>
                                <td class="text-end fw-bold">@Money(TotalCargos)</td>
                                @if (puedeEditar) { <td></td> }
                            </tr>
                            <tr>
                                <td class="text-muted" colspan="@(puedeEditar ? 4 : 2)">Pagado</td>
                                <td class="text-end text-success">@Money(TotalPagado)</td>
                                @if (puedeEditar) { <td></td> }
                            </tr>
                            <tr>
                                <td class="fw-semibold" colspan="@(puedeEditar ? 4 : 2)">Saldo pendiente</td>
                                <td class="text-end fw-semibold @(Saldo > 0 ? "text-danger" : "text-success")">@Money(Saldo)</td>
                                @if (puedeEditar) { <td></td> }
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
            }

            @if (puedeEditar)
            {
                <hr />
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <button class="btn btn-sm btn-outline-primary" @onclick="GenerarDesdeTarifarioAsync" disabled="@procesando">
                        <span class="bi bi-magic"></span> Generar cargos desde el tarifario
                    </button>
                    @if (cargosPeriodo.Count > 0)
                    {
                        <button class="btn btn-sm btn-primary" @onclick="GuardarCambiosCargosAsync" disabled="@procesando">
                            <span class="bi bi-save"></span> Guardar cambios
                        </button>
                    }
                    @if (mensajeCargos is not null) { <span class="text-success align-self-center small">@mensajeCargos</span> }
                </div>

                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small">Concepto (manual)</label>
                        <input class="form-control form-control-sm" @bind="nuevoCargo.Concepto" placeholder="Ej. Maniobra extra" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Tipo</label>
                        <select class="form-select form-select-sm" @bind="nuevoCargo.Tipo">
                            @foreach (var t in Enum.GetValues<TipoCargo>())
                            {
                                <option value="@t">@TipoTexto(t)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Cantidad</label>
                        <input type="number" min="1" class="form-control form-control-sm" @bind="nuevoCargo.Cantidad" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Precio unitario</label>
                        <input type="number" step="0.01" class="form-control form-control-sm" @bind="nuevoCargo.PrecioUnitario" />
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-sm btn-success w-100" @onclick="AgregarCargoAsync" disabled="@procesando">+ Agregar</button>
                    </div>
                </div>
                <p class="text-muted small mt-2 mb-0">
                    El importe se calcula solo (Cantidad × Precio unitario). En «Descuento» el importe se resta automáticamente.
                </p>
            }
        </div>
    </div>

    @* ---------- Pagos y facturas del periodo ---------- *@
    <div class="card mb-4">
        <div class="card-body p-4">
            <h5 class="text-primary mb-3">Pagos y facturas de @NombresMes.Get(PeriodoMes) @PeriodoAnio</h5>

            @if (puedeEditar)
            {
                @* Vista de administrador: una tarjeta editable por pago (los campos se acomodan solos). *@
                @if (pagosPeriodo.Count == 0)
                {
                    <p class="text-muted"><em>Sin pagos en este periodo.</em></p>
                }
                else
                {
                    @foreach (var p in pagosPeriodo)
                    {
                        var pago = p;
                        <div class="border rounded p-3 mb-3 bg-light-subtle">
                            <div class="row g-3">
                                <div class="col-12 col-md-6 col-lg-3">
                                    <label class="form-label small mb-1">Fecha y hora</label>
                                    <input type="datetime-local" class="form-control form-control-sm" @bind="pago.Fecha" />
                                </div>
                                <div class="col-6 col-md-3 col-lg-2">
                                    <label class="form-label small mb-1">Monto</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">$</span>
                                        <input type="number" step="0.01" min="0" class="form-control text-end" @bind="pago.Monto" />
                                    </div>
                                </div>
                                <div class="col-6 col-md-3 col-lg-3">
                                    <label class="form-label small mb-1">Método de pago</label>
                                    <select class="form-select form-select-sm" @bind="pago.MetodoPago">
                                        @foreach (var m in Enum.GetValues<MetodoPago>())
                                        {
                                            <option value="@m">@MetodoTexto(m)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <label class="form-label small mb-1">Referencia</label>
                                    <input class="form-control form-control-sm" @bind="pago.Referencia" placeholder="Opcional" />
                                </div>

                                <div class="col-12 col-md-6 col-lg-5">
                                    <label class="form-label small mb-1">
                                        Factura XML
                                        @if (!string.IsNullOrEmpty(pago.XmlArchivo))
                                        {
                                            <a href="@pago.XmlArchivo" target="_blank" class="ms-1" title="Ver XML actual"><span class="bi bi-filetype-xml"></span> Ver actual</a>
                                        }
                                    </label>
                                    <InputFile OnChange="(e) => SubirXmlPago(e, pago)" class="form-control form-control-sm" accept=".xml" />
                                </div>
                                <div class="col-12 col-md-6 col-lg-5">
                                    <label class="form-label small mb-1">
                                        Factura PDF
                                        @if (!string.IsNullOrEmpty(pago.PdfArchivo))
                                        {
                                            <a href="@pago.PdfArchivo" target="_blank" class="ms-1 text-danger" title="Ver PDF actual"><span class="bi bi-filetype-pdf"></span> Ver actual</a>
                                        }
                                    </label>
                                    <InputFile OnChange="(e) => SubirPdfPago(e, pago)" class="form-control form-control-sm" accept=".pdf" />
                                </div>
                                <div class="col-12 col-lg-2 d-flex align-items-end justify-content-lg-end">
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarPagoAsync(pago.Id)" title="Eliminar pago">
                                        <span class="bi bi-trash"></span> Eliminar
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    <button class="btn btn-sm btn-primary" @onclick="GuardarCambiosPagosAsync" disabled="@procesando">
                        <span class="bi bi-save"></span> Guardar cambios de pagos
                    </button>
                    @if (subiendo) { <span class="text-muted ms-2 small">Subiendo archivo...</span> }
                    @if (mensajePago is not null) { <span class="text-success ms-2 small">@mensajePago</span> }
                }
            }
            else
            {
                @* Vista del cliente: solo lectura, en tabla. *@
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th class="text-end">Monto</th>
                                <th>Método de pago</th>
                                <th>Referencia</th>
                                <th class="text-center">XML</th>
                                <th class="text-center">PDF</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in pagosPeriodo)
                            {
                                <tr>
                                    <td>@p.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end fw-semibold">@Money(p.Monto)</td>
                                    <td>@p.MetodoTexto</td>
                                    <td>@(string.IsNullOrEmpty(p.Referencia) ? "—" : p.Referencia)</td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(p.XmlArchivo))
                                        {
                                            <a href="@p.XmlArchivo" target="_blank" title="Descargar XML"><span class="bi bi-filetype-xml fs-5"></span></a>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(p.PdfArchivo))
                                        {
                                            <a href="@p.PdfArchivo" target="_blank" title="Descargar PDF"><span class="bi bi-filetype-pdf fs-5 text-danger"></span></a>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                </tr>
                            }
                            @if (pagosPeriodo.Count == 0)
                            {
                                <tr><td colspan="6" class="text-center text-muted py-3">Sin pagos en este periodo.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (puedeEditar)
            {
                <hr />
                <h6 class="mb-3">Registrar pago de este periodo</h6>
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small">Fecha</label>
                        <input type="datetime-local" class="form-control form-control-sm" @bind="nuevoPago.Fecha" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Monto (MXN)</label>
                        <input type="number" step="0.01" class="form-control form-control-sm" @bind="nuevoPago.Monto" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Método</label>
                        <select class="form-select form-select-sm" @bind="nuevoPago.MetodoPago">
                            @foreach (var m in Enum.GetValues<MetodoPago>())
                            {
                                <option value="@m">@MetodoTexto(m)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Referencia (opcional)</label>
                        <input class="form-control form-control-sm" @bind="nuevoPago.Referencia" placeholder="Ej. TRX-001" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">XML factura</label>
                        <InputFile OnChange="SubirXml" class="form-control form-control-sm" accept=".xml" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">PDF factura</label>
                        <InputFile OnChange="SubirPdf" class="form-control form-control-sm" accept=".pdf" />
                    </div>
                    <div class="col-12 mt-2">
                        <button class="btn btn-sm btn-primary" @onclick="AgregarPagoAsync" disabled="@procesando">Registrar pago</button>
                        @if (subiendo) { <span class="text-muted ms-2 small">Subiendo archivo...</span> }
                        @if (mensajePago is not null) { <span class="text-success ms-2 small">@mensajePago</span> }
                    </div>
                </div>
            }
        </div>
    </div>

    @* ---------- Historial completo ---------- *@
    <div class="card">
        <div class="card-body p-4">
            <h5 class="text-primary mb-3">Historial completo de pagos</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Periodo</th>
                            <th>Fecha</th>
                            <th class="text-end">Monto</th>
                            <th>Método de pago</th>
                            <th class="text-center">XML</th>
                            <th class="text-center">PDF</th>
                            @if (puedeEditar) { <th></th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in pagosTodos)
                        {
                            <tr>
                                <td>@p.PeriodoTexto</td>
                                <td>@p.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end fw-semibold">@Money(p.Monto)</td>
                                <td>@p.MetodoTexto</td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(p.XmlArchivo))
                                    {
                                        <a href="@p.XmlArchivo" target="_blank" title="Descargar XML"><span class="bi bi-filetype-xml fs-5"></span></a>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(p.PdfArchivo))
                                    {
                                        <a href="@p.PdfArchivo" target="_blank" title="Descargar PDF"><span class="bi bi-filetype-pdf fs-5 text-danger"></span></a>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                @if (puedeEditar)
                                {
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarPagoAsync(p.Id)" title="Eliminar pago"><span class="bi bi-trash"></span></button>
                                    </td>
                                }
                            </tr>
                        }
                        @if (pagosTodos.Count == 0)
                        {
                            <tr><td colspan="@(puedeEditar ? 7 : 6)" class="text-center text-muted py-3">Sin pagos registrados.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool esAdmin;        // personal del almacén (ve todos los clientes con el selector)
    private bool puedeEditar;    // puede modificar (Admin/Cobranza); el Supervisor solo mira
    private bool cargando = true;
    private bool procesando;
    private int? clienteId;
    private string? usuario;

    private List<Cliente> clientes = [];
    private int clienteSeleccionado;

    // Periodo seleccionado, codificado como Anio*100 + Mes.
    private int periodoKey;
    private int PeriodoAnio => periodoKey / 100;
    private int PeriodoMes => periodoKey % 100;
    private List<(int Anio, int Mes)> periodos = [];

    private List<Cargo> cargosPeriodo = [];
    private List<Pago> pagosPeriodo = [];
    private List<Pago> pagosTodos = [];

    // Corte / liberación del periodo seleccionado.
    private CorteFacturacion? corte;
    private DateTime fechaCorteEdit;
    private bool Liberado => corte?.Liberado ?? false;

    private Cargo nuevoCargo = new();
    private Pago nuevoPago = new() { Fecha = DateTime.Now };
    private bool subiendo;
    private string? mensajePago;
    private string? mensajeCargos;

    private decimal TotalCargos => cargosPeriodo.Sum(c => c.Monto);
    private decimal TotalPagado => pagosPeriodo.Sum(p => p.Monto);
    private decimal Saldo => TotalCargos - TotalPagado;

    private string EstadoTexto =>
        TotalCargos == 0 ? "Sin cargos" :
        Saldo <= 0 ? "Pagado" :
        TotalPagado > 0 ? "Pago parcial" : "Pendiente";

    private string EstadoClase =>
        TotalCargos == 0 ? "text-bg-secondary" :
        Saldo <= 0 ? "text-bg-success" :
        TotalPagado > 0 ? "text-bg-warning" : "text-bg-danger";

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        esAdmin = user.EsPersonal();
        puedeEditar = user.PuedeEditarModulo(ModuloApp.Pagos);
        usuario = user.Identity?.Name;

        if (esAdmin)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            clientes = await db.Clientes.OrderBy(c => c.Nombre).ToListAsync();
            cargando = false;
        }
        else
        {
            clienteId = user.ClienteId();
            await CambiarClienteAsync();
        }
    }

    private async Task CambiarClienteAsync()
    {
        cargando = true;
        if (esAdmin)
            clienteId = clienteSeleccionado == 0 ? null : clienteSeleccionado;

        ResetForms();

        if (clienteId is int id)
        {
            await CargarPeriodosAsync(id);
            await CargarPeriodoAsync();
        }
        cargando = false;
    }

    private async Task CargarPeriodosAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var deCargos = await db.Cargos.Where(c => c.ClienteId == id)
            .Select(c => new { c.Anio, c.Mes }).Distinct().ToListAsync();
        var dePagos = await db.Pagos.Where(p => p.ClienteId == id)
            .Select(p => new { p.Anio, p.Mes }).Distinct().ToListAsync();

        var ahora = DateTime.Now;
        var conjunto = deCargos.Concat(dePagos)
            .Select(x => (x.Anio, x.Mes))
            .Append((ahora.Year, ahora.Month))
            .Distinct()
            .OrderByDescending(p => p.Item1).ThenByDescending(p => p.Item2)
            .ToList();

        periodos = conjunto;

        // Por defecto, el periodo actual.
        if (periodoKey == 0 || !periodos.Any(p => p.Anio * 100 + p.Mes == periodoKey))
            periodoKey = ahora.Year * 100 + ahora.Month;

        // Historial completo (todos los periodos).
        pagosTodos = await db.Pagos.Where(p => p.ClienteId == id)
            .OrderByDescending(p => p.Fecha).Take(200).ToListAsync();
    }

    private async Task CargarPeriodoAsync()
    {
        if (clienteId is not int id) return;

        mensajeCargos = null;
        mensajePago = null;

        await using var db = await DbFactory.CreateDbContextAsync();
        cargosPeriodo = await db.Cargos
            .Where(c => c.ClienteId == id && c.Anio == PeriodoAnio && c.Mes == PeriodoMes)
            .OrderBy(c => c.Id).ToListAsync();
        pagosPeriodo = await db.Pagos
            .Where(p => p.ClienteId == id && p.Anio == PeriodoAnio && p.Mes == PeriodoMes)
            .OrderByDescending(p => p.Fecha).ToListAsync();

        corte = await db.CortesFacturacion
            .FirstOrDefaultAsync(c => c.ClienteId == id && c.Anio == PeriodoAnio && c.Mes == PeriodoMes);
        // Por defecto, la fecha de corte propuesta es el último día del periodo.
        fechaCorteEdit = corte?.FechaCorte
            ?? new DateTime(PeriodoAnio, PeriodoMes, DateTime.DaysInMonth(PeriodoAnio, PeriodoMes));
    }

    /// <summary>Obtiene el corte del periodo o crea uno nuevo (sin guardar aún).</summary>
    private async Task<CorteFacturacion> ObtenerOCrearCorteAsync(ApplicationDbContext db, int id)
    {
        var c = await db.CortesFacturacion
            .FirstOrDefaultAsync(x => x.ClienteId == id && x.Anio == PeriodoAnio && x.Mes == PeriodoMes);
        if (c is null)
        {
            c = new CorteFacturacion { ClienteId = id, Anio = PeriodoAnio, Mes = PeriodoMes };
            db.CortesFacturacion.Add(c);
        }
        return c;
    }

    private async Task GuardarFechaCorteAsync()
    {
        if (clienteId is not int id) return;
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var c = await ObtenerOCrearCorteAsync(db, id);
            c.FechaCorte = fechaCorteEdit;
            await db.SaveChangesAsync();
            mensajeCargos = "Fecha de corte guardada.";
            await CargarPeriodoAsync();
        }
        finally { procesando = false; }
    }

    private async Task LiberarAsync(bool liberar)
    {
        if (clienteId is not int id) return;
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var c = await ObtenerOCrearCorteAsync(db, id);
            // Al liberar, conservar la fecha de corte capturada en pantalla si no había una.
            if (liberar && c.FechaCorte is null) c.FechaCorte = fechaCorteEdit;
            c.Liberado = liberar;
            c.LiberadoEn = liberar ? DateTime.Now : null;
            c.LiberadoPor = liberar ? usuario : null;
            await db.SaveChangesAsync();
            mensajeCargos = liberar
                ? "Estado de cuenta liberado: el cliente ya puede verlo."
                : "Estado de cuenta oculto al cliente.";
            await CargarPeriodoAsync();
        }
        finally { procesando = false; }
    }

    private async Task GenerarDesdeTarifarioAsync()
    {
        if (clienteId is not int id) return;
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var tarifario = await db.CostosServicio.Where(c => c.ClienteId == id).ToListAsync();
            if (tarifario.Count == 0)
            {
                mensajeCargos = "Este cliente no tiene tarifario. Defínelo en Clientes → Editar → Costos del servicio.";
                return;
            }

            // Conceptos que ya existen en el periodo, para no duplicar.
            var existentes = await db.Cargos
                .Where(c => c.ClienteId == id && c.Anio == PeriodoAnio && c.Mes == PeriodoMes)
                .Select(c => c.Concepto).ToListAsync();

            var agregados = 0;
            foreach (var t in tarifario)
            {
                if (existentes.Any(e => e.Equals(t.Concepto, StringComparison.OrdinalIgnoreCase))) continue;
                db.Cargos.Add(new Cargo
                {
                    ClienteId = id,
                    Anio = PeriodoAnio,
                    Mes = PeriodoMes,
                    Concepto = t.Concepto,
                    Tipo = TipoCargo.Servicio,
                    Cantidad = 1,
                    PrecioUnitario = t.ImporteNeto,
                    Monto = t.ImporteNeto
                });
                agregados++;
            }
            await db.SaveChangesAsync();
            mensajeCargos = agregados > 0
                ? $"{agregados} concepto(s) agregado(s) desde el tarifario."
                : "Todos los conceptos del tarifario ya estaban en este periodo.";
            await CargarPeriodoAsync();
        }
        finally { procesando = false; }
    }

    private async Task AgregarCargoAsync()
    {
        if (clienteId is not int id || string.IsNullOrWhiteSpace(nuevoCargo.Concepto)) return;
        procesando = true;
        try
        {
            RecalcularCargo(nuevoCargo);
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Cargos.Add(new Cargo
            {
                ClienteId = id,
                Anio = PeriodoAnio,
                Mes = PeriodoMes,
                Concepto = nuevoCargo.Concepto.Trim(),
                Tipo = nuevoCargo.Tipo,
                Cantidad = nuevoCargo.Cantidad <= 0 ? 1 : nuevoCargo.Cantidad,
                PrecioUnitario = nuevoCargo.PrecioUnitario,
                Monto = nuevoCargo.Monto
            });
            await db.SaveChangesAsync();
            nuevoCargo = new();
            await CargarPeriodoAsync();
        }
        finally { procesando = false; }
    }

    private async Task GuardarCambiosCargosAsync()
    {
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach (var c in cargosPeriodo)
            {
                c.Concepto = c.Concepto.Trim();
                RecalcularCargo(c);
                db.Cargos.Update(c);
            }
            await db.SaveChangesAsync();
            mensajeCargos = "Cambios guardados.";
        }
        finally { procesando = false; }
    }

    /// <summary>Recalcula el importe del cargo: Cantidad × Precio unitario (negativo en descuentos).</summary>
    private void RecalcularCargo(Cargo c)
    {
        if (c.Cantidad < 1) c.Cantidad = 1;
        var importe = c.Cantidad * c.PrecioUnitario;
        c.Monto = c.Tipo == TipoCargo.Descuento ? -Math.Abs(importe) : importe;
    }

    private async Task EliminarCargoAsync(int cargoId)
    {
        procesando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var cargo = await db.Cargos.FindAsync(cargoId);
            if (cargo is not null)
            {
                db.Cargos.Remove(cargo);
                await db.SaveChangesAsync();
            }
            await CargarPeriodoAsync();
        }
        finally { procesando = false; }
    }

