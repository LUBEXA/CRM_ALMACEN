@page "/pagos"
@attribute [Authorize]
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AlmacenamientoArchivos Almacenamiento

<PageTitle>Pagos y Facturación - CRM Almacén</PageTitle>

<h1>Pagos y Facturación</h1>

@if (esAdmin)
{
    <div class="card mb-3">
        <div class="card-body">
            <label class="form-label">Cliente</label>
            <select class="form-select" style="max-width:420px" @bind="clienteSeleccionado" @bind:after="CargarAsync">
                <option value="0">-- Selecciona un cliente --</option>
                @foreach (var c in clientes)
                {
                    <option value="@c.Id">@c.Nombre</option>
                }
            </select>
        </div>
    </div>
}

@if (cargando)
{
    <p><em>Cargando...</em></p>
}
else if (clienteId is null)
{
    <div class="alert alert-info">Selecciona un cliente para ver sus pagos.</div>
}
else
{
    @* ---------- Periodo actual ---------- *@
    <div class="card mb-4">
        <div class="card-body p-4">
            <h5 class="text-primary mb-3">Periodo actual <span class="text-muted fs-6">— @NombresMes.Get(DateTime.Now.Month) @DateTime.Now.Year</span></h5>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr><th>Concepto</th><th class="text-center">Cantidad</th><th class="text-end">Monto</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in cargosPeriodo)
                        {
                            <tr>
                                <td>@c.Concepto</td>
                                <td class="text-center">@c.Cantidad</td>
                                <td class="text-end">@Money(c.Monto)</td>
                            </tr>
                        }
                        @if (cargosPeriodo.Count == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted py-3">Sin cargos en el periodo actual.</td></tr>
                        }
                    </tbody>
                    @if (cargosPeriodo.Count > 0)
                    {
                        <tfoot>
                            <tr class="periodo-total">
                                <td class="fw-bold">Total a pagar</td>
                                <td></td>
                                <td class="text-end">
                                    <span class="btn btn-primary disabled w-100">Pagar @Money(TotalPeriodo)</span>
                                </td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>

            @if (esAdmin)
            {
                <hr />
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label small">Concepto</label>
                        <input class="form-control form-control-sm" @bind="nuevoCargo.Concepto" placeholder="Renta de tarima mediana" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Cantidad</label>
                        <input type="number" class="form-control form-control-sm" @bind="nuevoCargo.Cantidad" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Monto (MXN)</label>
                        <input type="number" step="0.01" class="form-control form-control-sm" @bind="nuevoCargo.Monto" />
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-sm btn-success w-100" @onclick="AgregarCargoAsync">+ Agregar cargo</button>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ---------- Historial de pagos ---------- *@
    <div class="card">
        <div class="card-body p-4">
            <h5 class="text-primary mb-3">Historial de pagos y facturación</h5>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th class="text-end">Monto</th>
                            <th>Método de pago</th>
                            <th class="text-center">XML</th>
                            <th class="text-center">PDF</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in pagos)
                        {
                            <tr>
                                <td>@p.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end fw-semibold">@Money(p.Monto)</td>
                                <td>@p.MetodoTexto</td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(p.XmlArchivo))
                                    {
                                        <a href="@p.XmlArchivo" target="_blank" title="Descargar XML"><span class="bi bi-filetype-xml fs-5"></span></a>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(p.PdfArchivo))
                                    {
                                        <a href="@p.PdfArchivo" target="_blank" title="Descargar PDF"><span class="bi bi-filetype-pdf fs-5 text-danger"></span></a>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                            </tr>
                        }
                        @if (pagos.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center text-muted py-3">Sin pagos registrados.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (esAdmin)
            {
                <hr />
                <h6 class="mb-3">Registrar pago</h6>
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small">Fecha</label>
                        <input type="datetime-local" class="form-control form-control-sm" @bind="nuevoPago.Fecha" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">Monto (MXN)</label>
                        <input type="number" step="0.01" class="form-control form-control-sm" @bind="nuevoPago.Monto" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Método</label>
                        <select class="form-select form-select-sm" @bind="nuevoPago.MetodoPago">
                            @foreach (var m in Enum.GetValues<MetodoPago>())
                            {
                                <option value="@m">@MetodoTexto(m)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">XML factura</label>
                        <InputFile OnChange="SubirXml" class="form-control form-control-sm" accept=".xml" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">PDF factura</label>
                        <InputFile OnChange="SubirPdf" class="form-control form-control-sm" accept=".pdf" />
                    </div>
                    <div class="col-12 mt-2">
                        <button class="btn btn-sm btn-primary" @onclick="AgregarPagoAsync">Registrar pago</button>
                        @if (subiendo) { <span class="text-muted ms-2 small">Subiendo archivo...</span> }
                        @if (mensaje is not null) { <span class="text-success ms-2 small">@mensaje</span> }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool esAdmin;
    private bool cargando = true;
    private int? clienteId;
    private string? usuario;

    private List<Cliente> clientes = [];
    private int clienteSeleccionado;

    private List<Cargo> cargosPeriodo = [];
    private List<Pago> pagos = [];

    private Cargo nuevoCargo = new();
    private Pago nuevoPago = new() { Fecha = DateTime.Now };
    private bool subiendo;
    private string? mensaje;

    private decimal TotalPeriodo => cargosPeriodo.Sum(c => c.Monto);

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        esAdmin = user.EsAdmin();
        usuario = user.Identity?.Name;

        if (esAdmin)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            clientes = await db.Clientes.OrderBy(c => c.Nombre).ToListAsync();
            cargando = false;
        }
        else
        {
            clienteId = user.ClienteId();
            await CargarAsync();
        }
    }

    private async Task CargarAsync()
    {
        cargando = true;
        if (esAdmin)
            clienteId = clienteSeleccionado == 0 ? null : clienteSeleccionado;

        if (clienteId is int id)
        {
            var ahora = DateTime.Now;
            await using var db = await DbFactory.CreateDbContextAsync();
            cargosPeriodo = await db.Cargos
                .Where(c => c.ClienteId == id && c.Anio == ahora.Year && c.Mes == ahora.Month)
                .OrderBy(c => c.Id).ToListAsync();
            pagos = await db.Pagos
                .Where(p => p.ClienteId == id)
                .OrderByDescending(p => p.Fecha).Take(100).ToListAsync();
        }
        cargando = false;
    }

    private async Task AgregarCargoAsync()
    {
        if (clienteId is not int id || string.IsNullOrWhiteSpace(nuevoCargo.Concepto) || nuevoCargo.Monto < 0) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Cargos.Add(new Cargo
        {
            ClienteId = id,
            Anio = DateTime.Now.Year,
            Mes = DateTime.Now.Month,
            Concepto = nuevoCargo.Concepto,
            Cantidad = nuevoCargo.Cantidad <= 0 ? 1 : nuevoCargo.Cantidad,
            Monto = nuevoCargo.Monto
        });
        await db.SaveChangesAsync();
        nuevoCargo = new();
        await CargarAsync();
    }

    private async Task SubirXml(InputFileChangeEventArgs e)
    {
        if (clienteId is not int id) return;
        subiendo = true;
        try { nuevoPago.XmlArchivo = await Almacenamiento.GuardarAsync(e.File, $"clientes/{id}/facturas", "factura"); }
        finally { subiendo = false; }
    }

    private async Task SubirPdf(InputFileChangeEventArgs e)
    {
        if (clienteId is not int id) return;
        subiendo = true;
        try { nuevoPago.PdfArchivo = await Almacenamiento.GuardarAsync(e.File, $"clientes/{id}/facturas", "factura"); }
        finally { subiendo = false; }
    }

    private async Task AgregarPagoAsync()
    {
        if (clienteId is not int id || nuevoPago.Monto <= 0) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Pagos.Add(new Pago
        {
            ClienteId = id,
            Fecha = nuevoPago.Fecha,
            Monto = nuevoPago.Monto,
            MetodoPago = nuevoPago.MetodoPago,
            XmlArchivo = nuevoPago.XmlArchivo,
            PdfArchivo = nuevoPago.PdfArchivo,
            RegistradoPor = usuario
        });
        await db.SaveChangesAsync();
        mensaje = "Pago registrado.";
        nuevoPago = new() { Fecha = DateTime.Now };
        await CargarAsync();
    }

    private static string Money(decimal m) => $"${m:N2} MXN";

    private static string MetodoTexto(MetodoPago m) => m switch
    {
        MetodoPago.Transferencia => "Transferencia interbancaria",
        MetodoPago.Efectivo => "Efectivo",
        MetodoPago.Tarjeta => "Tarjeta",
        MetodoPago.Cheque => "Cheque",
        _ => "Otro"
    };
}
