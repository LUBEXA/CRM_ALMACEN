@page "/ubicaciones"
@attribute [Authorize(Policy = "Ver:OcupacionAlmacen")]
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Ubicaciones - CRM Almacén</PageTitle>

<h1>🗺️ Ubicaciones del almacén</h1>
<p class="text-muted">
    Da de alta tus pasillos, racks o posiciones con el cupo de cada uno. Esto permite
    saber cuánto espacio tienes disponible en el <a href="ocupacion">reporte de ocupación</a>.
</p>

@if (puedeEditar)
{
    <div class="mb-3">
        @if (!mostrarFormulario)
        {
            <button class="btn btn-primary" @onclick="AbrirFormulario">
                <span class="bi bi-plus-lg"></span> Agregar ubicación
            </button>
        }
        else
        {
            <button class="btn btn-outline-secondary" @onclick="CerrarFormulario">
                <span class="bi bi-x-lg"></span> Cerrar formulario
            </button>
        }
    </div>
}

@if (mensaje is not null)
{
    <div class="alert @(error ? "alert-danger" : "alert-success")">@mensaje</div>
}

@if (puedeEditar && mostrarFormulario)
{
<div class="card mb-4">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <button class="nav-link @(modoGenerador ? "" : "active")" @onclick="() => modoGenerador = false">
                    Agregar una posición
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(modoGenerador ? "active" : "")" @onclick="() => modoGenerador = true">
                    Generar varias (rack completo)
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        @if (!modoGenerador)
        {
            <p class="text-muted small mb-3">Usa esto para dar de alta <strong>un solo hueco</strong>. Si vas a capturar un rack entero, usa la otra pestaña.</p>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">¿En qué pasillo está?</label>
                    <input class="form-control" @bind="nuevaZona" placeholder="Ej. Pasillo 1" />
                    <div class="form-text">El pasillo o zona donde se encuentra el rack.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Rack</label>
                    <input class="form-control text-uppercase" maxlength="4" @bind="nuevoRack" @bind:event="oninput" placeholder="A" />
                    <div class="form-text">Ponle una letra al rack: A, B, C…</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">¿Cuántas tarimas caben aquí?</label>
                    <input type="number" min="1" class="form-control" @bind="nuevaCapacidad" />
                    <div class="form-text">Normalmente 1 tarima por hueco.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Nivel (altura)</label>
                    <input type="number" min="1" class="form-control" @bind="nuevoNivel" @bind:event="oninput" />
                    <div class="form-text">1 = piso. 2, 3… más arriba.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Posición (hueco)</label>
                    <input type="number" min="1" class="form-control" @bind="nuevaPosicion" @bind:event="oninput" />
                    <div class="form-text">El número de hueco a lo largo del rack.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Notas</label>
                    <input class="form-control" @bind="nuevasNotas" placeholder="Opcional (ej. refrigerado)" />
                    <div class="form-text">Opcional.</div>
                </div>
                <div class="col-12 d-flex align-items-center justify-content-between flex-wrap gap-2 border-top pt-3">
                    <span class="text-muted">Este hueco se llamará: <code class="fs-6">@VistaPreviaCodigo()</code></span>
                    <button class="btn btn-primary" @onclick="AgregarAsync" disabled="@guardando">
                        <span class="bi bi-plus-lg"></span> Agregar hueco
                    </button>
                </div>
            </div>
        }
        else
        {
            <p class="text-muted small mb-3">
                Crea <strong>todos los huecos de un rack de una sola vez</strong>. Dile qué rack es, cuántos niveles
                tiene y cuántas posiciones, y el sistema genera todos los códigos solo.
            </p>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">¿En qué pasillo está?</label>
                    <input class="form-control" @bind="genZona" placeholder="Ej. Pasillo 1" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Rack</label>
                    <input class="form-control text-uppercase" maxlength="4" @bind="genRack" @bind:event="oninput" placeholder="A" />
                    <div class="form-text">Ponle una letra: A, B, C…</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">¿Cuántas tarimas caben por hueco?</label>
                    <input type="number" min="1" class="form-control" @bind="genCapacidad" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">¿Cuántos niveles (alturas) tiene el rack?</label>
                    <div class="input-group">
                        <span class="input-group-text">Del nivel</span>
                        <input type="number" min="1" class="form-control" @bind="genNivelDesde" @bind:event="oninput" />
                        <span class="input-group-text">al</span>
                        <input type="number" min="1" class="form-control" @bind="genNivelHasta" @bind:event="oninput" />
                    </div>
                    <div class="form-text">Ej. del 1 al 3 = 3 niveles.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">¿Cuántas posiciones (huecos) por nivel?</label>
                    <div class="input-group">
                        <span class="input-group-text">De la</span>
                        <input type="number" min="1" class="form-control" @bind="genPosDesde" @bind:event="oninput" />
                        <span class="input-group-text">a la</span>
                        <input type="number" min="1" class="form-control" @bind="genPosHasta" @bind:event="oninput" />
                    </div>
                    <div class="form-text">Ej. de la 1 a la 50 = 50 posiciones.</div>
                </div>
                <div class="col-12 d-flex align-items-center justify-content-between flex-wrap gap-2 border-top pt-3">
                    <span class="text-muted">@ResumenGenerador()</span>
                    <button class="btn btn-primary" @onclick="GenerarAsync" disabled="@guardando">
                        <span class="bi bi-grid-3x3-gap"></span> Generar todo el rack
                    </button>
                </div>
            </div>
        }
    </div>
</div>
}

@if (ubicaciones is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <p class="text-muted small">@ubicaciones.Count ubicación(es)</p>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Zona / Pasillo</th>
                    <th>Código</th>
                    <th class="text-end">Cupo</th>
                    <th class="text-end">Ocupado</th>
                    <th>Notas</th>
                    <th>Estado</th>
                    @if (puedeEditar) { <th class="text-end" style="width:170px"></th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var u in ubicaciones)
                {
                    var item = u;
                    var ocupado = ocupacionPorUbicacion.GetValueOrDefault(item.Id, 0);
                    @if (puedeEditar && editandoId == item.Id)
                    {
                        <tr>
                            <td><input class="form-control form-control-sm" @bind="item.Zona" /></td>
                            <td><input class="form-control form-control-sm" @bind="item.Codigo" /></td>
                            <td><input type="number" min="1" class="form-control form-control-sm text-end" @bind="item.Capacidad" style="max-width:90px" /></td>
                            <td class="text-end">@ocupado</td>
                            <td><input class="form-control form-control-sm" @bind="item.Notas" /></td>
                            <td>
                                <div class="form-check form-switch">
                                    <input type="checkbox" class="form-check-input" @bind="item.Activo" />
                                    <label class="form-check-label small">@(item.Activo ? "Activa" : "Inactiva")</label>
                                </div>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-primary" @onclick="() => GuardarFilaAsync(item)" disabled="@guardando">
                                    <span class="bi bi-check-lg"></span> Guardar
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicion" disabled="@guardando">Cancelar</button>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(item.Zona) ? "—" : item.Zona)</td>
                            <td><code>@item.Codigo</code></td>
                            <td class="text-end">@item.Capacidad</td>
                            <td class="text-end">
                                @ocupado
                                @if (ocupado >= item.Capacidad)
                                {
                                    <span class="badge text-bg-danger ms-1">Lleno</span>
                                }
                                else if (ocupado == 0)
                                {
                                    <span class="badge text-bg-success ms-1">Libre</span>
                                }
                            </td>
                            <td class="text-muted small">@item.Notas</td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="badge text-bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">Inactiva</span>
                                }
                            </td>
                            @if (puedeEditar)
                            {
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => editandoId = item.Id" disabled="@guardando">
                                        <span class="bi bi-pencil"></span> Editar
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAsync(item)" disabled="@guardando" title="Eliminar">
                                        <span class="bi bi-trash"></span>
                                    </button>
                                </td>
                            }
                        </tr>
                    }
                }
                @if (ubicaciones.Count == 0)
                {
                    <tr><td colspan="@(puedeEditar ? 7 : 6)" class="text-center text-muted py-4">Todavía no hay ubicaciones. Agrega la primera arriba.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool puedeEditar;
    private bool mostrarFormulario;
    private bool modoGenerador;
    private List<Ubicacion>? ubicaciones;
    private Dictionary<int, int> ocupacionPorUbicacion = new();
    private string? nuevaZona, nuevoRack, nuevasNotas;
    private int nuevoNivel = 1, nuevaPosicion = 1;
    private int nuevaCapacidad = 1;
    // Generador masivo
    private string? genZona, genRack;
    private int genNivelDesde = 1, genNivelHasta = 1, genPosDesde = 1, genPosHasta = 1, genCapacidad = 1;
    private int? editandoId;
    private string? mensaje;
    private bool error;
    private bool guardando;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        puedeEditar = user.PuedeEditarModulo(ModuloApp.Inventario);
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        ubicaciones = await db.Ubicaciones.OrderBy(u => u.Zona).ThenBy(u => u.Codigo).ToListAsync();
        ocupacionPorUbicacion = await db.Entradas
            .Where(e => e.UbicacionId != null && e.Producto!.Activo && e.Producto.CantidadDisponible > 0)
            .GroupBy(e => e.UbicacionId!.Value)
            .Select(g => new { g.Key, Total = g.Sum(e => e.Posiciones) })
            .ToDictionaryAsync(x => x.Key, x => x.Total);
    }

    private string VistaPreviaCodigo() =>
        string.IsNullOrWhiteSpace(nuevoRack) ? "—" : Ubicacion.ArmarCodigo(nuevoRack, nuevoNivel, nuevaPosicion);

    private string ResumenGenerador()
    {
        if (string.IsNullOrWhiteSpace(genRack))
            return "Escribe la letra del rack para ver cuántos huecos se crearán.";
        if (genNivelHasta < genNivelDesde || genPosHasta < genPosDesde)
            return "Revisa los rangos: el segundo número no puede ser menor que el primero.";
        var niveles = genNivelHasta - genNivelDesde + 1;
        var posiciones = genPosHasta - genPosDesde + 1;
        var total = niveles * posiciones;
        var primero = Ubicacion.ArmarCodigo(genRack, genNivelDesde, genPosDesde);
        var ultimo = Ubicacion.ArmarCodigo(genRack, genNivelHasta, genPosHasta);
        return $"Se crearán {total} huecos (del {primero} al {ultimo}).";
    }

    private void AbrirFormulario()
    {
        mensaje = null;
        error = false;
        nuevaZona = nuevoRack = nuevasNotas = null;
        nuevoNivel = nuevaPosicion = nuevaCapacidad = 1;
        mostrarFormulario = true;
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        nuevaZona = nuevoRack = nuevasNotas = null;
        nuevoNivel = nuevaPosicion = nuevaCapacidad = 1;
        mensaje = null;
        error = false;
    }

    private void CancelarEdicion()
    {
        editandoId = null;
        _ = CargarAsync();
    }

    private async Task AgregarAsync()
    {
        mensaje = null;
        error = false;
        var rack = nuevoRack?.Trim();
        if (string.IsNullOrWhiteSpace(rack))
        {
            error = true;
            mensaje = "Escribe la letra del rack (ej. A).";
            return;
        }
        if (nuevoNivel < 1 || nuevaPosicion < 1)
        {
            error = true;
            mensaje = "El nivel y la posición deben ser al menos 1.";
            return;
        }
        if (nuevaCapacidad < 1)
        {
            error = true;
            mensaje = "El cupo debe ser al menos 1.";
            return;
        }

        var codigo = Ubicacion.ArmarCodigo(rack, nuevoNivel, nuevaPosicion);

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.Ubicaciones.AnyAsync(u => u.Codigo == codigo))
            {
                error = true;
                mensaje = $"Ya existe una ubicación con el código '{codigo}'.";
                return;
            }
            db.Ubicaciones.Add(new Ubicacion
            {
                Zona = string.IsNullOrWhiteSpace(nuevaZona) ? null : nuevaZona.Trim(),
                Rack = rack.ToUpperInvariant(),
                Nivel = nuevoNivel,
                Posicion = nuevaPosicion,
                Codigo = codigo,
                Capacidad = nuevaCapacidad,
                Notas = string.IsNullOrWhiteSpace(nuevasNotas) ? null : nuevasNotas.Trim(),
                Activo = true
            });
            await db.SaveChangesAsync();
            mensaje = $"Ubicación '{codigo}' agregada.";
            nuevaZona = nuevoRack = nuevasNotas = null;
            nuevoNivel = nuevaPosicion = nuevaCapacidad = 1;
            mostrarFormulario = false;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private async Task GenerarAsync()
    {
        mensaje = null;
        error = false;
        var rack = genRack?.Trim();
        if (string.IsNullOrWhiteSpace(rack))
        {
            error = true;
            mensaje = "Escribe la letra del rack (ej. A).";
            return;
        }
        if (genNivelDesde < 1 || genPosDesde < 1 || genNivelHasta < genNivelDesde || genPosHasta < genPosDesde)
        {
            error = true;
            mensaje = "Revisa los rangos: el 'hasta' no puede ser menor que el 'desde'.";
            return;
        }
        if (genCapacidad < 1)
        {
            error = true;
            mensaje = "El cupo debe ser al menos 1.";
            return;
        }

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existentes = await db.Ubicaciones.Select(u => u.Codigo).ToListAsync();
            var yaExisten = new HashSet<string>(existentes);
            var zona = string.IsNullOrWhiteSpace(genZona) ? null : genZona.Trim();
            var rackUp = rack.ToUpperInvariant();
            int creadas = 0, omitidas = 0;

            for (var nivel = genNivelDesde; nivel <= genNivelHasta; nivel++)
            {
                for (var pos = genPosDesde; pos <= genPosHasta; pos++)
                {
                    var codigo = Ubicacion.ArmarCodigo(rackUp, nivel, pos);
                    if (!yaExisten.Add(codigo)) { omitidas++; continue; }
                    db.Ubicaciones.Add(new Ubicacion
                    {
                        Zona = zona,
                        Rack = rackUp,
                        Nivel = nivel,
                        Posicion = pos,
                        Codigo = codigo,
                        Capacidad = genCapacidad,
                        Activo = true
                    });
                    creadas++;
                }
            }
            await db.SaveChangesAsync();
            mensaje = $"Se crearon {creadas} ubicación(es) del rack {rackUp}." +
                      (omitidas > 0 ? $" {omitidas} ya existían y se omitieron." : "");
            mostrarFormulario = false;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private async Task GuardarFilaAsync(Ubicacion u)
    {
        mensaje = null;
        error = false;
        u.Codigo = u.Codigo?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(u.Codigo))
        {
            error = true;
            mensaje = "La ubicación necesita un código.";
            return;
        }
        if (u.Capacidad < 1)
        {
            error = true;
            mensaje = "El cupo debe ser al menos 1.";
            return;
        }

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.Ubicaciones.AnyAsync(x => x.Codigo == u.Codigo && x.Id != u.Id))
            {
                error = true;
                mensaje = $"Ya existe otra ubicación con el código '{u.Codigo}'.";
                return;
            }
            u.Zona = string.IsNullOrWhiteSpace(u.Zona) ? null : u.Zona.Trim();
            u.Notas = string.IsNullOrWhiteSpace(u.Notas) ? null : u.Notas.Trim();
            db.Ubicaciones.Update(u);
            await db.SaveChangesAsync();
            mensaje = "Cambios guardados.";
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }

    private async Task EliminarAsync(Ubicacion u)
    {
        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Ubicaciones.Remove(u);
            await db.SaveChangesAsync();
            mensaje = $"Ubicación '{u.Codigo}' eliminada.";
            error = false;
            editandoId = null;
            await CargarAsync();
        }
        finally { guardando = false; }
    }
}
