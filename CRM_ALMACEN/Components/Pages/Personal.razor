@page "/personal"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager

<PageTitle>Personal y accesos - CRM Almacén</PageTitle>

<h1><span class="bi bi-person-badge-fill"></span> Personal y accesos</h1>
<p class="text-muted">
    Colaboradores de la empresa que pueden iniciar sesión. El <strong>rol</strong> es una
    plantilla que define sus accesos iniciales; con <strong>«Editar accesos»</strong> puedes
    ajustar pantalla por pantalla qué ve y qué puede modificar cada persona.
</p>

<div class="card shadow-sm mb-4">
    <div class="card-header">Registrar nuevo colaborador</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Correo de acceso (usuario)</label>
                <input class="form-control" @bind="nuevoCorreo" placeholder="persona@empresa.com" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Nombre para mostrar</label>
                <input class="form-control" @bind="nuevoNombre" placeholder="Nombre de la persona" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Rol</label>
                <select class="form-select" @bind="nuevoRol">
                    @foreach (var r in DbSeeder.RolesInternos)
                    {
                        <option value="@r.Rol">@r.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="CrearAsync" disabled="@procesando">
                    Crear acceso
                </button>
            </div>
        </div>

        @if (credenciales.Count > 0)
        {
            <div class="alert alert-success mt-3 mb-0">
                <strong>Contraseña temporal generada.</strong>
                Compártela con la persona; el sistema le pedirá cambiarla en su primer ingreso.
                @foreach (var c in credenciales)
                {
                    <ul class="mb-0 mt-2">
                        <li>Usuario (correo): <code>@c.Correo</code></li>
                        <li>Contraseña temporal: <code>@c.Password</code></li>
                    </ul>
                }
            </div>
        }
        @if (error is not null)
        {
            <div class="alert alert-danger mt-3 mb-0">@error</div>
        }
    </div>
</div>

@if (usuarios is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr><th>Correo</th><th>Nombre</th><th style="min-width:220px">Rol</th><th>Estado</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var u in usuarios)
            {
                var item = u;
                <tr>
                    <td>@item.Usuario.Email</td>
                    <td>@item.Usuario.NombreCompleto</td>
                    <td>
                        <span class="badge text-bg-primary">@DbSeeder.NombreRol(item.Rol)</span>
                        @if (item.Usuario.Id == miId)
                        {
                            <div class="small text-muted">(tu propia cuenta)</div>
                        }
                    </td>
                    <td>
                        @if (item.Usuario.RequiereCambioPassword)
                        {
                            <span class="badge text-bg-warning">Contraseña temporal pendiente</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">Activo</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (item.Rol != DbSeeder.RolAdmin)
                        {
                            <a class="btn btn-sm btn-outline-primary" href="personal/editar/@item.Usuario.Id">
                                <span class="bi bi-sliders"></span> Editar accesos
                            </a>
                        }
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => RestablecerAsync(item.Usuario.Id)" disabled="@procesando">
                            <span class="bi bi-key"></span> Restablecer contraseña
                        </button>
                        @if (item.Usuario.Id != miId)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAsync(item.Usuario.Id)" disabled="@procesando">
                                <span class="bi bi-trash"></span> Quitar
                            </button>
                        }
                    </td>
                </tr>
            }
            @if (usuarios.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted py-4">Sin colaboradores registrados.</td></tr>
            }
        </tbody>
    </table>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private record UsuarioConRol(ApplicationUser Usuario, string Rol);

    private List<UsuarioConRol>? usuarios;
    private string? miId;

    private string? nuevoCorreo;
    private string? nuevoNombre;
    private string nuevoRol = DbSeeder.RolAlmacenista;

    private string? error;
    private bool procesando;
    private readonly List<(string Correo, string Password)> credenciales = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        miId = UserManager.GetUserId(user);
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        // Personal = usuarios sin cliente asociado (Admin y roles internos).
        var lista = UserManager.Users
            .Where(u => u.ClienteId == null)
            .OrderBy(u => u.Email)
            .ToList();

        var resultado = new List<UsuarioConRol>();
        foreach (var u in lista)
        {
            var roles = await UserManager.GetRolesAsync(u);
            resultado.Add(new UsuarioConRol(u, roles.FirstOrDefault() ?? ""));
        }
        usuarios = resultado;
    }

    private async Task CrearAsync()
    {
        error = null;
        credenciales.Clear();

        var correo = nuevoCorreo?.Trim();
        if (string.IsNullOrWhiteSpace(correo))
        {
            error = "Escribe un correo electrónico para el acceso.";
            return;
        }
        if (await UserManager.FindByEmailAsync(correo) is not null)
        {
            error = $"Ya existe un usuario con el correo '{correo}'. Usa otro correo.";
            return;
        }

        procesando = true;
        try
        {
            var passwordTemporal = GenerarPasswordTemporal();
            var usuario = new ApplicationUser
            {
                UserName = correo,
                Email = correo,
                EmailConfirmed = true,
                NombreCompleto = string.IsNullOrWhiteSpace(nuevoNombre) ? correo : nuevoNombre,
                RequiereCambioPassword = true
            };

            var creado = await UserManager.CreateAsync(usuario, passwordTemporal);
            if (!creado.Succeeded)
            {
                error = "No se pudo crear el acceso: "
                    + string.Join(" ", creado.Errors.Select(e => e.Description));
                return;
            }

            await UserManager.AddToRoleAsync(usuario, nuevoRol);
            credenciales.Add((correo, passwordTemporal));
            nuevoCorreo = null;
            nuevoNombre = null;
            nuevoRol = DbSeeder.RolAlmacenista;
            await CargarAsync();
        }
        finally { procesando = false; }
    }

    private async Task RestablecerAsync(string userId)
    {
        error = null;
        credenciales.Clear();

        procesando = true;
        try
        {
            var usuario = await UserManager.FindByIdAsync(userId);
            if (usuario is null) return;

            var passwordTemporal = GenerarPasswordTemporal();
            var token = await UserManager.GeneratePasswordResetTokenAsync(usuario);
            var resultado = await UserManager.ResetPasswordAsync(usuario, token, passwordTemporal);
            if (!resultado.Succeeded)
            {
                error = "No se pudo restablecer la contraseña: "
                    + string.Join(" ", resultado.Errors.Select(e => e.Description));
                return;
            }

            usuario.RequiereCambioPassword = true;
            await UserManager.UpdateAsync(usuario);
            credenciales.Add((usuario.Email!, passwordTemporal));
            await CargarAsync();
        }
        finally { procesando = false; }
    }

    private async Task EliminarAsync(string userId)
    {
        error = null;
        credenciales.Clear();
        if (userId == miId) return; // nunca eliminar la propia cuenta

        procesando = true;
        try
        {
            var usuario = await UserManager.FindByIdAsync(userId);
            if (usuario is null) return;

            var resultado = await UserManager.DeleteAsync(usuario);
            if (!resultado.Succeeded)
            {
                error = "No se pudo quitar el acceso: "
                    + string.Join(" ", resultado.Errors.Select(e => e.Description));
                return;
            }
            await CargarAsync();
        }
        finally { procesando = false; }
    }

    private static string GenerarPasswordTemporal()
    {
        var numero = Random.Shared.Next(1000, 9999);
        return $"Lbx{numero}$";
    }
}
