@* Checkbox oculto que controla el modo contraído del menú (CSS puro). Arranca contraído. *@
<input type="checkbox" id="sidebar-collapse" class="sidebar-collapse-toggle" checked />

<div class="sidebar-brand">
    <a class="navbar-brand" href="">
        <span class="brand-logo"><span class="bi bi-box-seam-fill"></span></span>
        <span class="link-text">CRM Almacén</span>
    </a>
    <label for="sidebar-collapse" class="sidebar-collapse-btn" title="Contraer / expandir menú">
        <span class="bi bi-chevron-double-left"></span>
    </label>
    <AuthorizeView>
        <Authorized>
            <div class="sidebar-empresa">
                <span class="bi bi-building"></span>
                <span class="text-truncate link-text">@context.User.NombreParaMostrar()</span>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

<input type="checkbox" title="Menú" id="navmenu-toggle" class="navmenu-icon" />
<label for="navmenu-toggle" class="navmenu-icon"><span class="bi bi-list"></span></label>

<div class="nav-scrollable">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" title="Inicio">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> <span class="link-text">Inicio</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="perfil" title="Perfil">
                <span class="bi bi-person-badge" aria-hidden="true"></span> <span class="link-text">Perfil</span>
            </NavLink>
        </div>
        <AuthorizeView Policy="Ver:Pagos">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="pagos" title="Pagos y Facturación">
                    <span class="bi bi-credit-card-2-front" aria-hidden="true"></span> <span class="link-text">Pagos y Facturación</span>
                </NavLink>
            </div>
        </AuthorizeView>
        <AuthorizeView Policy="Ver:Inventario">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="existencias" title="Inventario">
                    <span class="bi bi-box-seam" aria-hidden="true"></span> <span class="link-text">Inventario</span>
                </NavLink>
            </div>
        </AuthorizeView>
        <AuthorizeView Policy="Ver:OcupacionAlmacen">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="ocupacion" title="Ocupación del almacén">
                    <span class="bi bi-pie-chart-fill" aria-hidden="true"></span> <span class="link-text">Ocupación</span>
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="ubicaciones" title="Ubicaciones">
                    <span class="bi bi-geo-alt-fill" aria-hidden="true"></span> <span class="link-text">Ubicaciones</span>
                </NavLink>
            </div>
        </AuthorizeView>
        <AuthorizeView Policy="Ver:Movimientos">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="movimientos" title="Movimientos (entradas y salidas)">
                    <span class="bi bi-arrow-down-up" aria-hidden="true"></span> <span class="link-text">Movimientos</span>
                </NavLink>
            </div>
        </AuthorizeView>
        <AuthorizeView Policy="Ver:Solicitudes">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="solicitudes" title="Solicitudes de pedido">
                    <span class="bi bi-card-checklist" aria-hidden="true"></span> <span class="link-text">Solicitudes de pedido</span>
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Policy="EsCliente">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="mis-movimientos" title="Movimientos de mi mercancía">
                    <span class="bi bi-arrow-down-up" aria-hidden="true"></span> <span class="link-text">Movimientos</span>
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="mis-pedidos" title="Historial de pedidos">
                    <span class="bi bi-clock-history" aria-hidden="true"></span> <span class="link-text">Historial de pedidos</span>
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Policy="VerAdministracion">
            <div class="nav-section"><span class="link-text">Administración</span></div>
        </AuthorizeView>
        <AuthorizeView Policy="Ver:Clientes">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="clientes" title="Clientes">
                    <span class="bi bi-people-fill" aria-hidden="true"></span> <span class="link-text">Clientes</span>
                </NavLink>
            </div>
        </AuthorizeView>
        <AuthorizeView Policy="Ver:Productos">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="productos" title="Productos">
                    <span class="bi bi-tags-fill" aria-hidden="true"></span> <span class="link-text">Productos</span>
                </NavLink>
            </div>
        </AuthorizeView>
        <AuthorizeView Policy="Ver:ListaPrecios">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="lista-precios" title="Lista de precios">
                    <span class="bi bi-cash-stack" aria-hidden="true"></span> <span class="link-text">Lista de precios</span>
                </NavLink>
            </div>
        </AuthorizeView>
        <AuthorizeView Roles="Admin">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="personal" title="Personal y accesos">
                    <span class="bi bi-person-badge-fill" aria-hidden="true"></span> <span class="link-text">Personal y accesos</span>
                </NavLink>
            </div>
        </AuthorizeView>
    </nav>
</div>
