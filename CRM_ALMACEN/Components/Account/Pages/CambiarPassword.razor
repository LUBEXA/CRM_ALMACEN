@page "/Account/CambiarPassword"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>Cambiar contraseña - CRM Almacén</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <h1 class="login-title">🔐 Cambiar contraseña</h1>

        @if (esTemporal)
        {
            <p class="text-muted text-center mb-4">
                Estás usando una contraseña temporal. Por seguridad, define tu propia
                contraseña para continuar.
            </p>
        }
        else
        {
            <p class="text-muted text-center mb-4">
                Define una nueva contraseña para tu cuenta.
            </p>
        }

        <form method="post" action="Account/CambiarPassword">
            <AntiforgeryToken />

            @if (ErrorParam == "match")
            {
                <div class="alert alert-danger" role="alert">Las contraseñas nuevas no coinciden.</div>
            }
            else if (ErrorParam == "actual")
            {
                <div class="alert alert-danger" role="alert">La contraseña actual es incorrecta.</div>
            }
            else if (ErrorParam == "policy")
            {
                <div class="alert alert-danger" role="alert">
                    La contraseña no cumple los requisitos. Usa al menos 6 caracteres
                    e incluye un símbolo (por ejemplo: <code>$ # @@ !</code>).
                </div>
            }

            <div class="form-floating mb-3">
                <input name="actual" type="password" class="form-control" id="actual"
                       autocomplete="current-password" required placeholder="Contraseña actual" />
                <label for="actual">Contraseña actual @(esTemporal ? "(la temporal)" : "")</label>
            </div>

            <div class="form-floating mb-3">
                <input name="password" type="password" class="form-control" id="password"
                       autocomplete="new-password" required minlength="6" placeholder="Nueva contraseña" />
                <label for="password">Nueva contraseña</label>
            </div>

            <div class="form-floating mb-3">
                <input name="confirmar" type="password" class="form-control" id="confirmar"
                       autocomplete="new-password" required minlength="6" placeholder="Repetir contraseña" />
                <label for="confirmar">Repetir nueva contraseña</label>
            </div>

            <p class="small text-muted mb-3">
                Mínimo 6 caracteres e incluye al menos un símbolo (<code>$ # @@ !</code>).
            </p>

            <button type="submit" class="btn btn-primary w-100 py-2">Guardar contraseña</button>

            @if (!esTemporal)
            {
                <a href="/" class="btn btn-link w-100 mt-2">Cancelar</a>
            }
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? ErrorParam { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool esTemporal;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        esTemporal = user.RequiereCambioPassword();
    }
}
